---
/**
 * Iconos y copy desde Figma MCP — frame 4003-204
 * https://www.figma.com/design/ytKtPJwjbmgRlAmik1SM2x/LANDING-PAGE-PROBUSINESS--Copy-?node-id=4003-204
 * Las URLs figma.com/api/mcp/asset/… caducan ~7 días; descarga a /public/icons/howitworks/ y sustituye.
 */
const A = "https://www.figma.com/api/mcp/asset";

type Step = {
  num: number;
  title: string;
  desc: string;
  /** Una URL o dos capas (contenedor Figma = 2 vectores) */
  icon: string | readonly [string, string];
  highlighted?: boolean;
};

function isDualIcon(icon: Step["icon"]): icon is readonly [string, string] {
  return Array.isArray(icon);
}

const steps: Step[] = [
  {
    num: 1,
    title: "Cotización",
    desc: "Nos compartes la cotización de tu proveedor y te calculamos el costo total de tu importación hasta entregartelo en tus manos.",
    icon: `${A}/77b177e7-fd0a-42be-978e-83b1f9f9e97c`,
  },
  {
    num: 2,
    title: "Pago proveedor",
    desc: "Te ayudamos a realizar el pago en China desde Perú, de forma segura y sin complicaciones.",
    icon: `${A}/4b607ea2-df3c-4fb3-8175-0445dd8abee2`,
  },
  {
    num: 3,
    title: "Inspección en tiempo real",
    desc: "Cuando tu carga llega a nuestro almacén en China, te enviamos la inspección para confirmación.",
    icon: `${A}/b53882de-ad9c-4df1-a059-b5de62f39de4`,
  },
  {
    num: 4,
    title: "Consolidado y envío",
    desc: "Llenamos el contenedor junto con otros importadores y enviamos tu carga a Perú.",
    icon: [
      `${A}/05df9cac-b370-42a8-8806-9dcfc3e73b6b`,
      `${A}/7bc5e27d-03ef-4909-9fce-fb1573af2591`,
    ],
  },
  {
    num: 5,
    title: "Aduana incluída",
    desc: "Nos encargamos de todos los trámites aduaneros.",
    icon: `${A}/e019c95b-6fd5-4a8b-8384-53c339e71b5f`,
  },
  {
    num: 6,
    title: "Acompañamiento 360",
    desc: "Estamos contigo en cada paso. Sin costos ocultos, sin sorpresas.",
    icon: `${A}/05c16af3-fad6-43f1-a612-d8e9219d6a9e`,
    highlighted: true,
  },
];

/** Camión / fondo — mismo frame MCP */
const imgCamionFigma = `${A}/d2c3b3b6-51f0-43b4-84a0-5161bc2f383b`;
---

<section class="howitworks" aria-labelledby="howitworks-heading">
  <div class="howitworks-bg">
    <div class="howitworks-wrap">
      <div class="howitworks-intro">
        <p class="howitworks-eyebrow">cómo funciona</p>
        <h2 id="howitworks-heading" class="howitworks-title">
          <span class="howitworks-title-line">Tu importación</span>
          <span class="howitworks-title-accent">paso a paso</span>
        </h2>
        <p class="howitworks-desc">
          Con carga consolidada <strong
            >varios importadores comparten un contenedor.</strong
          > Tú pagas solo por lo que traes, con acompañamiento en cada etapa del proceso.
        </p>
      </div>

      <div class="howitworks-board">
        <div class="steps-grid steps-grid--desktop" role="list">
          {
            steps.map((step) => (
              <article class:list={["step-card"]} role="listitem">
                <img
                  src="https://cdn.probusiness.pe/landingconsolidado/images/step_deco.webp"
                  style="position: absolute; top: 1px; right: -20px;"
                  class=""
                  aria-hidden="true"
                />
                <div
                  class:list={[
                    "step-icon-wrap",
                    { "step-icon-wrap--on-dark": step.highlighted },
                    { "step-icon-wrap--dual": isDualIcon(step.icon) },
                  ]}
                >
                  {isDualIcon(step.icon) ? (
                    <>
                      <img
                        src={step.icon[0]}
                        alt=""
                        class="step-icon-img step-icon-img--layer"
                        width="32"
                        height="32"
                        loading="lazy"
                        decoding="async"
                      />
                      <img
                        src={step.icon[1]}
                        alt=""
                        class="step-icon-img step-icon-img--layer step-icon-img--layer-front"
                        width="32"
                        height="32"
                        loading="lazy"
                        decoding="async"
                      />
                    </>
                  ) : (
                    <img
                      src={step.icon}
                      alt=""
                      class="step-icon-img"
                      width="28"
                      height="28"
                      loading="lazy"
                      decoding="async"
                    />
                  )}
                </div>
                <h3 class="step-title">{step.title}</h3>
                <span class="step-num">Paso {step.num}</span>
                <p class="step-desc">{step.desc}</p>
              </article>
            ))
          }
        </div>

       
      </div>
    </div>
    <div class="howitworks-truck" aria-hidden="true">
      <img
        src={imgCamionFigma}
        alt=""
        class="howitworks-truck-img"
        width="1000"
        height="1000"
        loading="lazy"
        decoding="async"
        data-fallback="https://cdn.probusiness.pe/landingconsolidado/images/camion.webp"
      />
    </div>
  </div>
</section>

<script>
  document
    .querySelectorAll<HTMLImageElement>(".howitworks-truck-img[data-fallback]")
    .forEach((img) => {
      img.addEventListener(
        "error",
        () => {
          const fb = img.dataset.fallback;
          if (fb && img.src !== fb) img.src = fb;
        },
        { once: true },
      );
    });
</script>

<style>
  .howitworks {
    position: relative;
    /* El camión usa ancho fijo + translateX; evita scroll horizontal en toda la página */
    overflow-x: hidden;
  }

  .howitworks-bg {
    background: #fffbf8;
    overflow-x: hidden;
    padding: 5em 0;
    
  }
  @media (max-width: 768px) {
    .howitworks-bg {
      padding: 3em 0;
    }
  }

  .howitworks-wrap {
    width: 80%;
    margin: 0 auto;
    box-sizing: border-box;
  }

  /* Bloque cabecera: una sola columna, todo alineado a la izquierda */
  .howitworks-intro {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    gap: 0;
    margin-bottom: clamp(40px, 5vw, 56px);
    max-width: 100%;
  }

  .howitworks-eyebrow {
    margin: 0 0 16px;
    color: #ff500b;
    font-family: "Sora", sans-serif;
    font-size: 20px;
    font-style: normal;
    font-weight: 400;
    line-height: 126%;
    text-transform: uppercase;
  }

  .howitworks-title {
    font-family: var(--font-display-serif);
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin: 0 0 20px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
  }

  .howitworks-title-line {
    font-family: var(--font-heading);
    font-weight: 300;
    color: #7e3407;
    font-family: Epilogue;
    font-size: 64px;
    font-style: normal;
    font-weight: 400;
    line-height: 90%; /* 57.6px */
    letter-spacing: -3.84px;
  }

  .howitworks-title-accent {
    background: var(
      --ORANGE-WHITE,
      linear-gradient(90deg, #000 0%, #ff5410 25.48%)
    );
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-family: Epilogue;
    font-size: 64px;
    font-style: normal;
    font-weight: 400;
    line-height: 90%;
    letter-spacing: -3.84px;
  }

  .howitworks-desc {
    font-family: var(--font-body);
    font-size: clamp(15px, 1.4vw, 17px);
    font-weight: 400;
    color: #2d2926;
    max-width: min(640px, 100%);
    line-height: 1.65;
    margin: 0;
  }

  .howitworks-desc strong {
    font-weight: 700;
  }

  /* Grilla 4 arriba + 2 abajo; hueco derecho para camión */
  .howitworks-board {
    position: relative;
    min-height: clamp(320px, 42vw, 420px);
  }

  .steps-grid--desktop {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(50px, 4vw, 48px);
    position: relative;
    padding: 2em 0;
    z-index: 1;
  }

  .howitworks-truck {
    position: absolute;
    right: 0;
    bottom:0;
    width: 100%;
    
    pointer-events: none;
    z-index: 0;
    opacity: 0.85;
    /* Recorta la imagen desplazada con translateX para que no genere overflow */
    overflow: hidden;
  }

  .howitworks-truck::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    /* Difumina bordes superior e inferior para ocultar líneas de corte */
    background:
      linear-gradient(
        180deg,
        #fffbf8 0%,
        rgba(255, 251, 248, 0.92) 7%,
        rgba(255, 251, 248, 0.55) 14%,
        rgba(255, 251, 248, 0.16) 22%,
        rgba(255, 251, 248, 0) 30%
      ),
      linear-gradient(
        0deg,
        #fffbf8 0%,
        rgba(255, 251, 248, 0.92) 8%,
        rgba(255, 251, 248, 0.55) 16%,
        rgba(255, 251, 248, 0.16) 24%,
        rgba(255, 251, 248, 0) 34%
      );
    filter: drop-shadow(0 4px 4px rgba(0, 0, 0, 0.25));
  }

  .howitworks-truck-img {
    position: relative;
    z-index: 0;
    width: min(1200px, 110vw);
    height: auto;
    display: block;
    object-fit: contain;
    object-position: bottom right;
    filter: grayscale(25%) brightness(1.08);
    mask-image: linear-gradient(
      115deg,
      transparent 0%,
      rgba(0, 0, 0, 0.35) 35%,
      black 72%
    );
    -webkit-mask-image: linear-gradient(
      115deg,
      transparent 0%,
      rgba(0, 0, 0, 0.35) 35%,
      black 72%
    );
    opacity: 1;
    scale: 1.8;
    /** Empieza más a la derecha para recortar más el lado derecho */
    transform: translateX(55%);
  }

  .step-card {
    position: relative;
    border-radius: 18px;
    border: 1px solid rgba(0, 0, 0, 0.1);
    background: #fff7f4;
    padding: 26px 24px;
    min-height: clamp(390px, 22vw, 440px);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
    overflow: hidden;
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.04);
    width: 80%;
    margin: 0 auto;
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease,
      background 0.25s ease,
      border-color 0.25s ease;
  }

  .step-card:hover {
    transform: translateY(-3px);
  }

  /* Tarjetas claras → fondo naranja al hover (texto e icono en modo claro) */
  .step-card:not(.step-card--highlighted):hover {
    background: var(--gradient-card-step6);
    border-color: rgba(255, 255, 255, 0.35);
    box-shadow: 0 20px 50px rgba(232, 68, 3, 0.35);
  }

  .step-card:not(.step-card--highlighted):hover .step-card-deco {
    opacity: 0.2;
    background: radial-gradient(circle at 70% 30%, #fff 0%, transparent 50%);
  }

  .step-card:not(.step-card--highlighted):hover .step-title {
    color: #fff;
  }

  .step-card:not(.step-card--highlighted):hover .step-num {
    color: rgba(255, 255, 255, 0.85);
  }

  .step-card:not(.step-card--highlighted):hover .step-desc {
    color: rgba(255, 255, 255, 0.95);
  }

  .step-card:not(.step-card--highlighted):hover .step-icon-wrap {
    background: rgba(255, 255, 255, 0.22);
    border: 1px solid rgba(255, 255, 255, 0.45);
  }

  .step-card--highlighted:hover {
    box-shadow: 0 24px 56px rgba(232, 68, 3, 0.45);
    filter: brightness(1.03);
  }

  /* Tarjetas 5 y 6: fila 2, solo dos columnas */
  .step-card:nth-child(5) {
    grid-column: 1;
    grid-row: 2;
  }

  .step-card:nth-child(6) {
    grid-column: 2;
    grid-row: 2;
  }

  .step-card-deco {
    position: absolute;
    top: 0;
    right: 0;
    width: 100px;
    height: 100px;
    opacity: 0.14;
    background:
      radial-gradient(circle at 70% 30%, #ff6b35 0%, transparent 45%),
      radial-gradient(circle at 40% 60%, #ff9f7a 0%, transparent 40%),
      radial-gradient(circle at 85% 75%, #ffb899 0%, transparent 35%);
    pointer-events: none;
  }

  .step-card--highlighted {
    border-radius: 18px;
    background: linear-gradient(145deg, #ff7a41 0%, #ff500b 48%, #e84403 100%);
    border: 1px solid rgba(255, 255, 255, 0.35);
    box-shadow: none;
  }

  .step-card--highlighted .step-card-deco {
    opacity: 0.2;
    background: radial-gradient(circle at 70% 30%, #fff 0%, transparent 50%);
  }

  .step-title,
  .step-num,
  .step-desc,
  .step-icon-wrap {
    transition:
      color 0.25s ease,
      background 0.25s ease,
      border-color 0.25s ease;
  }

  .step-icon-wrap {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    border: 1px solid transparent;
    background: rgba(255, 107, 53, 0.14);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: #d94816;
    margin-bottom: 4px;
  }

  .step-icon-wrap--on-dark {
    background: rgba(255, 255, 255, 0.22);
    border: 1px solid rgba(255, 255, 255, 0.45);
    color: #fff;
  }

  .step-icon-wrap--dual {
    position: relative;
  }

  .step-icon-img {
    width: 28px;
    height: 28px;
    max-width: none;
    object-fit: contain;
    object-position: center;
    display: block;
  }

  .step-icon-wrap--dual .step-icon-img--layer {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 32px;
    height: 32px;
  }

  .step-icon-wrap--dual .step-icon-img--layer-front {
    z-index: 1;
  }

  .step-title {
    font-family: "Sora", var(--font-heading), sans-serif;
    font-size: clamp(18px, 1.7vw, 22px);
    font-weight: 600;
    color: var(--color-step-title);
    line-height: 1.25;
    margin: 0;
  }

  .step-card--highlighted .step-title {
    color: #fff;
  }

  .step-num {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    letter-spacing: 0.02em;
    text-transform: none;
    color: #838383;
    order: 0;
  }

  .step-card--highlighted .step-num {
    color: rgba(255, 255, 255, 0.85);
  }

  .step-desc {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    color: #5c5c5c;
    line-height: 1.55;
    margin: 0;
    padding-top: 8px;
    /* Último texto anclado abajo en desktop */
    margin-top: auto;
  }

  .step-card--highlighted .step-desc {
    color: rgba(255, 255, 255, 0.95);
  }

  /* Tablet: 2 cols, camión más bajo */
  @media (max-width: 900px) {
    .steps-grid--desktop {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .step-card:nth-child(5),
    .step-card:nth-child(6) {
      grid-column: auto;
      grid-row: auto;
    }

    .howitworks-truck {
      width: 100%;
      min-width: 360px;
      height: 100px;
      opacity:1;
      overflow: clip;
    }
  }

  /* Móvil: contenedor 90%, intro más pequeña, cards en 2 columnas, más padding abajo */
  @media (max-width: 768px) {
    .howitworks-bg {
      padding-bottom: 0;
    }

    .howitworks-wrap {
     width: 100%;
    }

    .howitworks-intro {
      margin-bottom: clamp(20px, 5vw, 32px);
      padding: 0 1em;
    }

    .howitworks-eyebrow {
      font-size: 14px;
      margin: 0 0 10px;
    }

    .howitworks-title {
      margin: 0 0 12px;
    }

    .howitworks-title-line,
    .howitworks-title-accent {
      font-size: clamp(28px, 7.5vw, 40px);
      letter-spacing: -0.06em;
      line-height: 1;
    }

    .howitworks-desc {
      font-size: 13px;
      line-height: 1.55;
    }

    .steps-grid--desktop {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px 10px;
      position: relative;
      z-index: 1;
    }

    .step-card {
      width: 100%;
      margin: 0;
      min-height: 240px;
      max-height: 240px;
      padding: 14px 12px;
      border-radius: 14px;
      background: rgba(255, 247, 244, 0.92);
      border-color: rgba(0, 0, 0, 0.08);
      box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08);
    }

    /* Mobile: última card siempre naranja */
    .step-card:last-child,
    .step-card--highlighted {
      background: linear-gradient(145deg, #ff7a41 0%, #ff500b 48%, #e84403 100%);
      border: 1px solid rgba(255, 255, 255, 0.35);
      box-shadow: 0 16px 34px rgba(232, 68, 3, 0.35);
    }

    .step-card:last-child .step-title,
    .step-card:last-child .step-num,
    .step-card:last-child .step-desc,
    .step-card--highlighted .step-title,
    .step-card--highlighted .step-num,
    .step-card--highlighted .step-desc {
      color: rgba(255, 255, 255, 0.95);
    }

    .step-card:last-child .step-icon-wrap,
    .step-card--highlighted .step-icon-wrap {
      background: rgba(255, 255, 255, 0.22);
      border: 1px solid rgba(255, 255, 255, 0.45);
      color: #fff;
    }

    .step-title {
      font-size: 13px;
    }

    .step-num {
      font-size: 12px;
    }

    .step-desc {
      font-size: 12px;
      line-height: 1.35;
      padding-top: 5px;
      margin-top: 0;
    }

    .step-icon-wrap {
      width: 44px;
      height: 44px;
    }

    .step-icon-img {
      width: 22px;
      height: 22px;
    }

    .howitworks-board {
      min-height: 0;
      border-radius: 16px;
      padding: 10px;
      overflow: hidden;
      isolation: isolate;
    }

    /* Mobile: imagen + degradados propios (separados del tratamiento desktop) */
    .howitworks-board::after {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background:
        linear-gradient(
          180deg,
          rgba(255, 251, 248, 0.9) 0%,
          rgba(255, 251, 248, 0.35) 22%,
          rgba(255, 251, 248, 0.12) 44%,
          rgba(255, 251, 248, 0.7) 100%
        ),
        linear-gradient(
          90deg,
          rgba(255, 251, 248, 0.95) 0%,
          rgba(255, 251, 248, 0.38) 38%,
          rgba(255, 251, 248, 0.1) 65%,
          rgba(255, 251, 248, 0.8) 100%
        ),
        url("https://cdn.probusiness.pe/landingconsolidado/images/camion.webp") no-repeat right center / cover;
      opacity: 0.55;
    }

    /* En mobile, ocultamos el truck de desktop para no mezclar efectos */
    .howitworks-truck {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .howitworks-wrap {
      width: 100%;
      padding: 0;
    }

    .steps-grid--desktop {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .step-card {
      min-height: 240px;
      max-height: 240px;
      padding: 12px 10px;
    }
  }
</style>
