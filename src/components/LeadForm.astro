---
const leadEndpoint = import.meta.env.PUBLIC_LANDING_CONSOLIDADO_LEAD_ENDPOINT ?? "";
const leadToken = import.meta.env.PUBLIC_LANDING_CONSOLIDADO_FORM_TOKEN ?? "";

interface Props {
  /** Código de campaña (ej. mar2026), coincide con la ruta /{codigo}/ */
  campaignCode: string;
  /** Ruta de la página de gracias para esta campaña, ej. /mar2026/gracias */
  graciasPath: string;
}

const { campaignCode, graciasPath } = Astro.props;
---

<section class="lead-form" id="form" aria-labelledby="lead-form-title">
  <div class="lead-form-inner container">
    <p class="lead-form-eyebrow">ASEGURA TU ESPACIO</p>
    <h2 id="lead-form-title" class="lead-form-title">Únete al próximo consolidado</h2>
    <p class="lead-form-sub">
      Déjanos tus datos y un asesor te contactará para calcular tu importación
    </p>

    <p class="lead-form-feedback" data-lead-feedback role="status" aria-live="polite"></p>

    <form class="lead-form-form" data-lead-form novalidate>
      <div class="lead-form-row">
        <div class="lead-field-box">
          <label for="lead-nombre" class="lead-field-box-label">Nombre Completo</label>
          <input
            id="lead-nombre"
            type="text"
            name="nombre"
            class="lead-field-box-input"
            placeholder="e.g José Gutiérrez"
            autocomplete="name"
            required
          />
        </div>
        <div class="lead-field-box">
          <label for="lead-whatsapp" class="lead-field-box-label">Número de WhatsApp</label>
          <input
            id="lead-whatsapp"
            type="tel"
            name="whatsapp"
            class="lead-field-box-input"
            placeholder="999 999 999"
            autocomplete="tel"
            inputmode="tel"
            required
          />
        </div>
      </div>

      <div class="lead-field-block">
        <label class="lead-select-question" for="lead-proveedor">¿Ya tienes tu proveedor en China?</label>
        <div class="lead-field-box lead-field-box--select">
          <div class="lead-select-wrap">
            <select id="lead-proveedor" class="lead-select" name="proveedor" required>
              <option value="" disabled selected>Selecciona una opción</option>
              <option value="si">Sí, ya tengo proveedor</option>
              <option value="no">No, aún no tengo proveedor</option>
              <option value="buscando">Estoy buscando proveedor</option>
            </select>
            <svg
              class="lead-select-chevron"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </div>
        </div>
      </div>

      <button type="submit" class="lead-submit" data-lead-submit>
        Quiero importar con Pro Business
      </button>
    </form>
  </div>
</section>

<script define:vars={{ leadEndpoint, leadToken, campaignCode, graciasPath }}>
  (function () {
    const SUCCESS_FLAG_KEY = "leadFormConfirmed";
    const SUCCESS_AT_KEY = "leadFormConfirmedAt";
    const SUCCESS_REDIRECT_PATH = graciasPath;
    const form = document.querySelector("[data-lead-form]");
    const feedback = document.querySelector("[data-lead-feedback]");
    const submitBtn = document.querySelector("[data-lead-submit]");
    if (!form || !feedback) return;

    function setFeedback(text, state) {
      feedback.textContent = text;
      feedback.dataset.state = state || "";
    }

    /**
     * Sin action/method en el <form>: un envío nativo ya no hace POST a "#" (eso recargaba la página).
     * Siempre preventDefault en submit y enviamos solo con fetch.
     */
    async function sendLead() {
      if (!form.reportValidity()) return;

      if (!leadEndpoint || !leadToken) {
        setFeedback(
          "Falta configurar el envío del formulario (variables de entorno en el proyecto).",
          "error",
        );
        return;
      }

      setFeedback("");
      if (submitBtn instanceof HTMLButtonElement) {
        submitBtn.disabled = true;
        submitBtn.dataset.label = submitBtn.textContent || "";
        submitBtn.textContent = "Enviando…";
      }

      const fd = new FormData(form);
      const body = {
        nombre: String(fd.get("nombre") || "").trim(),
        whatsapp: String(fd.get("whatsapp") || "").trim(),
        proveedor: String(fd.get("proveedor") || "").trim(),
        codigo_campana: campaignCode,
      };

      try {
        const res = await fetch(leadEndpoint, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Accept: "application/json",
            Authorization: "Bearer " + leadToken,
          },
          body: JSON.stringify(body),
        });

        const data = await res.json().catch(function () {
          return {};
        });

        if (res.ok) {
          sessionStorage.setItem(SUCCESS_FLAG_KEY, "1");
          sessionStorage.setItem(SUCCESS_AT_KEY, String(Date.now()));
          form.reset();
          window.location.assign(SUCCESS_REDIRECT_PATH);
        } else if (res.status === 422 && data.errors) {
          const first = Object.values(data.errors)[0];
          const msg = Array.isArray(first) ? first[0] : String(first);
          setFeedback(msg || data.message || "Revisa los datos e inténtalo de nuevo.", "error");
        } else {
          setFeedback(
            data.message || "No se pudo enviar. Inténtalo más tarde o escríbenos por WhatsApp.",
            "error",
          );
        }
      } catch {
        setFeedback(
          "Error de red. Comprueba tu conexión o inténtalo más tarde.",
          "error",
        );
      } finally {
        if (submitBtn instanceof HTMLButtonElement) {
          submitBtn.disabled = false;
          if (submitBtn.dataset.label) submitBtn.textContent = submitBtn.dataset.label;
        }
      }
    }

    form.addEventListener("submit", function (e) {
      e.preventDefault();
      void sendLead();
    });
  })();
</script>

<style>
  .lead-form {
    background: #000;
    padding: clamp(72px, 10vw, 120px) 0;
  }

  .lead-form-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .lead-form-eyebrow {
    font-family: 'Sora', var(--font-heading), system-ui, sans-serif;
    font-size: clamp(12px, 1.8vw, 14px);
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #ff530f;
    text-align: center;
    margin: 0 0 20px;
  }

  .lead-form-title {
    font-family: 'Sora', var(--font-heading), system-ui, sans-serif;
    font-size: clamp(2rem, 5.5vw, 3.25rem);
    font-weight: 700;
    color: #fff;
    text-align: center;
    margin: 0 0 20px;
    line-height: 1.08;
    letter-spacing: -0.03em;
  }

  .lead-form-feedback {
    font-family: 'Epilogue', var(--font-body), system-ui, sans-serif;
    font-size: 0.95rem;
    line-height: 1.45;
    text-align: center;
    margin: 0 0 16px;
    min-height: 0;
  }

  .lead-form-feedback:empty {
    display: none;
  }

  .lead-form-feedback[data-state="ok"] {
    color: #7dffb2;
  }

  .lead-form-feedback[data-state="error"] {
    color: #ff8a65;
  }

  .lead-form-sub {
    font-family: 'Epilogue', var(--font-body), system-ui, sans-serif;
    font-size: clamp(1rem, 2.2vw, 1.25rem);
    font-weight: 400;
    color: #fff;
    text-align: center;
    margin: 0 auto 48px;
    max-width: 36em;
    line-height: 1.55;
    opacity: 0.95;
  }

  .lead-form-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .lead-form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  /* Caja gris oscura con etiqueta dentro arriba */
  .lead-field-box {
    background: #2a2a2a;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    padding: 14px 18px 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    transition: border-color 0.2s ease;
  }

  .lead-field-box:focus-within {
    border-color: rgba(255, 83, 15, 0.55);
  }

  .lead-field-box-label {
    font-family: 'Epilogue', var(--font-body), system-ui, sans-serif;
    font-size: 12px;
    font-weight: 400;
    color: #8a8a8a;
    line-height: 1.2;
  }

  .lead-field-box-input {
    width: 100%;
    background: transparent;
    border: none;
    padding: 0;
    margin: 0;
    font-family: 'Epilogue', var(--font-body), system-ui, sans-serif;
    font-size: clamp(17px, 2.2vw, 20px);
    font-weight: 400;
    color: #fff;
    outline: none;
    -webkit-appearance: none;
    appearance: none;
  }

  .lead-field-box-input::placeholder {
    color: #9b9b9b;
  }

  /* Evita el fondo claro de autofill del navegador */
  .lead-field-box-input:-webkit-autofill,
  .lead-field-box-input:-webkit-autofill:hover,
  .lead-field-box-input:-webkit-autofill:focus,
  .lead-field-box-input:-webkit-autofill:active {
    -webkit-text-fill-color: #fff;
    caret-color: #fff;
    box-shadow: 0 0 0 1000px #2a2a2a inset;
    -webkit-box-shadow: 0 0 0 1000px #2a2a2a inset;
    transition: background-color 9999s ease-in-out 0s;
  }

  .lead-field-block {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .lead-select-question {
    font-family: 'Epilogue', var(--font-body), system-ui, sans-serif;
    font-size: 13px;
    font-weight: 400;
    color: #fff;
    padding-left: 2px;
    line-height: 1.35;
  }

  .lead-field-box--select {
    padding: 12px 18px;
  }

  .lead-select-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }

  .lead-select {
    width: 100%;
    background: transparent;
    border: none;
    padding: 6px 40px 6px 0;
    font-family: 'Epilogue', var(--font-body), system-ui, sans-serif;
    font-size: clamp(17px, 2.2vw, 20px);
    font-weight: 400;
    color: #9b9b9b;
    cursor: pointer;
    outline: none;
    -webkit-appearance: none;
    appearance: none;
  }

  .lead-select:focus {
    color: #fff;
  }

  .lead-select option {
    background: #1a1a1a;
    color: #fff;
  }

  .lead-select-chevron {
    position: absolute;
    right: 2px;
    top: 50%;
    transform: translateY(-50%);
    color: #fff;
    pointer-events: none;
  }

  .lead-submit {
    width: 100%;
    margin-top: 8px;
    padding: 20px 24px;
    background: #ff530f;
    border: none;
    border-radius: 12px;
    font-family: 'Epilogue', var(--font-body), system-ui, sans-serif;
    font-size: clamp(1.05rem, 2.4vw, 1.35rem);
    font-weight: 700;
    color: #fff;
    cursor: pointer;
    transition:
      background 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;
    box-shadow: 0 8px 28px rgba(255, 83, 15, 0.35);
  }

  .lead-submit:hover:not(:disabled) {
    background: #e84403;
    transform: translateY(-2px);
    box-shadow: 0 12px 36px rgba(255, 83, 15, 0.4);
  }

  .lead-submit:disabled {
    opacity: 0.75;
    cursor: wait;
    transform: none;
  }

  .lead-submit:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 3px;
  }

  @media (max-width: 640px) {
    .lead-form-row {
      grid-template-columns: 1fr;
    }

    .lead-form-inner {
      width: 80%;
      max-width: 100%;
      margin-inline: auto;
      padding-inline: 0;
    }

    .lead-form-eyebrow,
    .lead-form-title,
    .lead-form-sub,
    .lead-field-box-label,
    .lead-field-box-input,
    .lead-select-question,
    .lead-select,
    .lead-submit {
      font-family: "Epilogue", var(--font-body), system-ui, sans-serif;
      font-weight: 400;
    }
  }
</style>
