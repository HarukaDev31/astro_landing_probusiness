---
/**
 * Figma: frame 4017-154 (cabecera) + 4017-159 (carrusel / pasos).
 * Carrusel en Vue (`TrustCarousel.vue`): animaciones con **anime.js** (createTimeline), sin JS suelto en esta sección.
 */
import TrustCarousel from './TrustCarousel.vue';

const FIGMA = 'https://www.figma.com/api/mcp/asset';

const slides = [
  {
    step: 1,
    labelBefore: 'Cotización del ',
    labelBold: 'cliente',
    labelAfter: '',
    figma: `${FIGMA}/dd55081e-fd8e-4854-bccc-6411ca2ed49b`,
    fallback: '/images/probbd.png',
  },
  {
    step: 2,
    labelBefore: 'Inspección de la ',
    labelBold: 'carga en China',
    labelAfter: '',
    figma: `${FIGMA}/7b51e738-9159-433e-9fe4-618adb5eee66`,
    fallback: '/images/chaleco.png',
  },
  {
    step: 3,
    labelBefore: 'Llenado de contenedor y ',
    labelBold: 'envío a Perú',
    labelAfter: '',
    figma: `${FIGMA}/aa32d3b7-d8e1-46cf-9999-1335b0dd5b42`,
    fallback: '/images/camion.jpg',
  },
  {
    step: 4,
    labelBefore: 'Arribo a ',
    labelBold: 'puerto',
    labelAfter: '',
    figma: `${FIGMA}/3fcf347e-94f5-413b-97ec-eae8ed5d61a0`,
    fallback: '/images/logisticweb.png',
  },
  {
    step: 5,
    labelBefore: '',
    labelBold: '',
    labelAfter: '',
    plain: 'Desaduanaje',
    figma: `${FIGMA}/a3eb46ab-5ccc-42e6-8fb6-ce3a58ff4634`,
    fallback: '/images/aduanaa.jpg',
  },
  {
    step: 6,
    labelBefore: 'Entrega de ',
    labelBold: 'mercancía',
    labelAfter: '',
    boldIsStrong: true,
    figma: `${FIGMA}/a6a104b9-f8cc-4d4b-a403-10b352e9403e`,
    fallback: '/images/listoimportar.png',
  },
];
---

<section class="trust-section" aria-labelledby="trust-heading">
  <div class="container trust-inner">
    <header class="trust-header">
      <p class="trust-eyebrow">Confia en nosotros</p>
      <h2 id="trust-heading" class="trust-title">
        <span class="trust-title-line"
          >Mas de <span class="trust-title-accent">10 años</span> consolidando</span
        >
        <span class="trust-title-line">carga desde China</span>
      </h2>
    </header>

    <TrustCarousel client:visible slides={slides} />
  </div>
</section>

<style>
  .trust-section {
    background: #000;
    width: 100%;
    padding: clamp(72px, 9vw, 112px) 0 clamp(88px, 11vw, 120px);
  }

  .trust-inner {
    width: 80%;
    max-width: var(--container-width, 1152px);
    margin-inline: auto;
    padding-inline: clamp(16px, 4vw, 24px);
  }

  .trust-header {
    text-align: left;
    margin-bottom: clamp(36px, 5vw, 52px);
    max-width: 44rem;
  }

  .trust-eyebrow {
    font-family: 'Sora', var(--font-heading), system-ui, sans-serif;
    font-size: clamp(14px, 1.8vw, 20px);
    font-weight: 400;
    line-height: 1.26;
    color: #ff733b;
    text-transform: uppercase;
    margin: 0 0 clamp(16px, 2.2vw, 24px);
    letter-spacing: 0.04em;
  }

  .trust-title {
    font-family: 'Epilogue', var(--font-heading), system-ui, sans-serif;
    font-size: clamp(2.25rem, 5.5vw, 4rem);
    font-weight: 300;
    color: #fff;
    letter-spacing: -0.06em;
    line-height: 0.92;
    margin: 0;
  }

  .trust-title-line {
    display: block;
  }

  .trust-title-line:first-child {
    margin-bottom: 0.06em;
  }

  .trust-title-accent {
    font-weight: 500;
    background: linear-gradient(90deg, #ff5410 0%, #ff733b 75.48%, #ff5410 100%);
    background-size: 120% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
  }
</style>
