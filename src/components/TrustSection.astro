---
const gallery = [
  { label: 'Cotización del cliente', img: '/images/probbd.png' },
  { label: 'Llenado de contenedor y envío a Perú', img: '/images/camion.jpg' },
  { label: 'Inspección de la carga en China', img: '/images/aduanaa.jpg' },
  { label: 'Entrega al importador en Perú', img: '/images/logisticweb.png' },
  { label: 'Trámites aduaneros', img: '/images/aduanaa.jpg' },
  { label: 'Clientes satisfechos', img: '/images/chaleco.png' },
];
---

<section class="trust-section">
  <div class="container">
    <div class="trust-header">
      <p class="trust-label trust-label--desktop">Confía en nosotros</p>
      <p class="trust-label trust-label--mobile">CONOCE SOBRE NOSOTROS</p>
      <h2 class="trust-title">
        Mas de <span class="trust-title-accent">10 años</span> consolidando<br />carga desde China
      </h2>
    </div>

    <div class="gallery-grid">
      {gallery.map((item) => (
        <div class="gallery-card">
          <img src={item.img} alt={item.label} class="gallery-img" />
          <div class="gallery-overlay">
            <span class="gallery-label">{item.label}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .trust-section {
    background: #000;
    padding: 80px 0 100px;
  }

  .trust-header {
    margin-bottom: 60px;
  }

  .trust-label {
    font-family: 'Sora', sans-serif;
    font-size: 18px;
    font-weight: 400;
    color: #FF723B;
    margin-bottom: 16px;
  }

  .trust-label--mobile {
    display: none;
    font-size: 13px;
    letter-spacing: 0.1em;
    color: #FF530F;
  }

  .trust-title-accent {
    color: #FF530F;
    font-weight: 600;
  }

  .trust-title {
    font-family: 'Epilogue', sans-serif;
    font-size: 64px;
    font-weight: 300;
    color: #fff;
    letter-spacing: -3.84px;
    line-height: 0.95;
    max-width: 700px;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .gallery-card {
    position: relative;
    border-radius: var(--radius-card-large);
    overflow: hidden;
    height: 400px;
    background: #D9D9D9;
    cursor: pointer;
  }

  .gallery-card:hover .gallery-img {
    transform: scale(1.04);
  }

  .gallery-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
    display: block;
  }

  .gallery-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, transparent 55%);
    display: flex;
    align-items: flex-end;
    padding: 28px 28px;
  }

  .gallery-label {
    font-family: 'Sora', sans-serif;
    font-size: 28px;
    font-weight: 400;
    color: #fff;
    line-height: 1.2;
    max-width: 320px;
  }

  @media (max-width: 900px) {
    .trust-title {
      font-size: 42px;
    }

    .gallery-card {
      height: 280px;
    }

    .gallery-label {
      font-size: 20px;
    }
  }

  @media (max-width: 768px) {
    .trust-label--desktop {
      display: none;
    }

    .trust-label--mobile {
      display: block;
    }
  }

  @media (max-width: 640px) {
    .gallery-grid {
      grid-template-columns: 1fr;
    }

    .trust-title {
      font-size: 32px;
      letter-spacing: -2px;
    }
  }
</style>
