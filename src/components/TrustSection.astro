<style>
  .trust-section {
    background: #000;
    width: 100%;
    padding: clamp(72px, 9vw, 112px) 0 clamp(88px, 11vw, 120px);
  }

  .trust-inner {
    width: 80%;
    max-width: var(--container-width, 1152px);
    margin-inline: auto;
    padding-inline: clamp(16px, 4vw, 24px);
  }
</style>
