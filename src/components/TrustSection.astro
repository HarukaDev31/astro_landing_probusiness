---
/**
 * Figma: frame 4017-154 (cabecera) + 4017-159 (carrusel / pasos).
 * Carrusel en Vue (`TrustCarousel.vue`): animaciones con **anime.js** (createTimeline), sin JS suelto en esta sección.
 */
import TrustCarousel from './TrustCarousel.vue';

