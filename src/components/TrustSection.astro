    fallback: 'https://cdn.probusiness.pe/landingconsolidado/images/trust-inspeccion.webp',
  },
  {
    step: 3,
    labelBefore: 'Llenado de contenedor y ',
    labelBold: 'envío a Perú',
    labelAfter: '',
    figma: 'https://cdn.probusiness.pe/landingconsolidado/images/trust-llenadocontenedor.webp',
    fallback: 'https://cdn.probusiness.pe/landingconsolidado/images/trust-llenadocontenedor.webp',
  },
  {
    step: 4,
    labelBefore: 'Arribo a ',
    labelBold: 'puerto',
    labelAfter: '',
    figma: 'https://www.figma.com/api/mcp/asset/3fcf347e-94f5-413b-97ec-eae8ed5d61a0',
    fallback: 'https://cdn.probusiness.pe/landingconsolidado/images/logisticweb.webp',
  },
  {
    step: 5,
    labelBefore: '',
    labelBold: '',
    labelAfter: '',
    plain: 'Desaduanaje',
    figma: 'https://cdn.probusiness.pe/landingconsolidado/images/trust-desaduanaje.webp',
    fallback: 'https://cdn.probusiness.pe/landingconsolidado/images/trust-desaduanaje.webp',
  },
  {
    step: 6,
    labelBefore: 'Entrega de ',
    labelBold: 'mercancía',
