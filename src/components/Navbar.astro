<nav class="navbar">
  <div class="navbar-inner container">
    <div class="navbar-logo">
      <img src="/images/logo-hero.png" alt="Pro Business" class="navbar-logo-img" />
    </div>
    <div class="navbar-actions">
      <a href="#form" class="navbar-cta">Cotizar Ahora</a>
      <button type="button" class="navbar-menu show-mobile-only flex" aria-label="Abrir menú">
        <span class="navbar-menu-icon" aria-hidden="true"></span>
      </button>
    </div>
  </div>
</nav>

<style>
  .navbar {
    position: absolute;
    top: 70px;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 20px 0;
  }

  .navbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  .navbar-logo {
    display: flex;
    align-items: center;
  }

  .navbar-logo svg text {
    font-family: 'Sora', sans-serif;
  }

  .navbar-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 24px;
    background: linear-gradient(to right, #FF530F, #E84403);
    border-radius: 10px;
    font-family: 'Epilogue', sans-serif;
    font-size: 18px;
    font-weight: 500;
    color: #fff;
    transition: opacity 0.2s;
    white-space: nowrap;
  }

  .navbar-cta:hover {
    opacity: 0.9;
  }

  @media (max-width: 768px) {
    .navbar {
      padding: 14px 0;
    }

    .navbar-cta {
      font-size: 14px;
      padding: 8px 16px;
    }
  }
</style>
