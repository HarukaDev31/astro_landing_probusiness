---
import SoonContainers from "./SoonContainers.vue";

interface Props {
  /** Etiquetas tipo SoonContainers: día + mes (ej. "16 Abril") */
  soonDates?: string[];
}

const { soonDates = ["16 Abril", "30 Abril"] } = Astro.props;
---

<section class="hero">
  <!-- Solo fondo fotográfico + collage 3D (texto en HeroMessaging) -->
  <div class="hero-desktop">
    <div class="hero-bg">
      <img src="/images/hero-bg-web.png" alt="" class="hero-bg-img" role="presentation" />
      <div class="hero-overlay"></div>
    </div>

    <div class="hero-desktop-shell">
      <div class="hero-stage-wrap">
        <div class="hero-stage">
        
          <img
            src="/images/salidas.png"
            alt="Próximas salidas de contenedor"
            class="hero-salidas hero-salidas-pos"
          />
          <img
            src="/images/probbd.png"
            alt=""
            class="hero-probbd hero-probbd-pos"
            role="presentation"
          />
          <img src="/images/calendarr.png" alt="" class="hero-calendarr hero-calendarr-pos" role="presentation" />
          <img src="/images/palet-desktop.png" alt="" class="hero-palet hero-palet-pos" role="presentation" />
          <div class="hero-dates hero-dates-pos">
            <SoonContainers client:load dates={soonDates} />
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="hero-mobile">
    <div class="hero-mobile-visual">
      <div class="hero-mobile-visual-bg"></div>
      <div class="hero-mobile-collage">
        <img src="/images/probbd.png" alt="" class="hero-mobile-probbd hero-mobile-probbd-pos" role="presentation" />
        <img src="/images/narnajonn.png" alt="" class="hero-mobile-box hero-mobile-box-pos" role="presentation" />
        <img src="/images/salidas.png" alt="" class="hero-mobile-salidas hero-mobile-salidas-pos" />
        <img src="/images/calendarr.png" alt="" class="hero-mobile-cal hero-mobile-cal-pos" role="presentation" />
        <img src="/images/palet-mobile.png" alt="" class="hero-mobile-palet hero-mobile-palet-pos" role="presentation" />
        <div class="hero-mobile-dates hero-mobile-dates-pos">
          <SoonContainers client:load dates={soonDates} />
        </div>
       
      </div>
    </div>
    <div class="hero-mobile-cta-wrap">
      <a href="#form" class="hero-mobile-cta">Cotizar Ahora</a>
    </div>
  </div>
</section>

<style>
  .hero {
    background: #000;
  }

  /*
    Diseño base: 620px de artboard con container 1152px (≈53.8%).
    Por debajo de ~1152 el ancho sigue el slot útil; por encima crece ~0.175px por px de viewport
    para que en monitores anchos el collage no quede “pequeño” y se mantenga el orden relativo.
  */
  .hero-desktop {
    position: relative;
    min-height: min(78vh, 820px);
    overflow: visible;
    padding-bottom: 40px;
    --hero-inline-pad: max(24px, calc((100vw - var(--container-width, 1152px)) / 2));
    --hero-slot: min(100vw - 2 * var(--hero-inline-pad), var(--container-width, 1152px));
    --hero-stage-w: clamp(
      300px,
      calc(var(--hero-slot) * 0.538 + max(0px, (100vw - var(--container-width, 1152px))) * 0.175),
      860px
    );
    --hero-stage-min-h: clamp(360px, calc(var(--hero-stage-w) * 0.71), 560px);
    --hero-stage-scale: calc(var(--hero-stage-w) / 620px);
    /* Baja todo el collage un poco (escala con el artboard) */
    --hero-collage-offset-y: calc(36px * var(--hero-stage-scale));
  }

  .hero-desktop-shell {
    position: relative;
    z-index: 5;
    width: 100%;
    margin: 0 auto;
    padding: 108px var(--hero-inline-pad) 0;
    display: flex;
    justify-content: center;
    align-items: flex-end;
    min-height: min(90vh, 740px);
    box-sizing: border-box;
  }

  .hero-stage-wrap {
    position: relative;
    width: var(--hero-stage-w);
    min-width: 0;
    min-height: var(--hero-stage-min-h);
  }

  @media (max-width: 1100px) {
    .hero-desktop-shell {
      min-height: 520px;
      padding-top: 96px;
    }

    .hero-desktop {
      --hero-stage-min-h: clamp(340px, calc(var(--hero-stage-w) * 0.65), 460px);
    }
  }

  .hero-stage-chevrons {
    position: absolute;
    left: 2%;
    bottom: 8%;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    pointer-events: none;
    opacity: 0.5;
    transform: scale(calc(1.15 * var(--hero-stage-scale)));
    transform-origin: left bottom;
  }

  .hero-chevron {
    display: block;
    width: 0;
    height: 0;
    border-left: 9px solid transparent;
    border-right: 9px solid transparent;
    border-bottom: 11px solid rgba(255, 255, 255, 0.42);
    margin-bottom: -5px;
  }

  .hero-chevron:last-child {
    margin-bottom: 0;
  }

  .hero-chevron--mobile {
    border-bottom-color: rgba(160, 160, 160, 0.75);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    border-radius: 0;
  }

  .hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 28%;
  }

  /*
    Degradado gris → negro sólido (#000) para empatar sin costura con HeroMessaging.
  */
  .hero-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(
      to bottom,
      rgba(100, 100, 100, 0.38) 0%,
      rgba(72, 72, 72, 0.52) 18%,
      rgba(38, 38, 38, 0.72) 42%,
      rgba(14, 14, 14, 0.92) 72%,
      #000000 100%
    );
  }

  .hero-stage {
    position: absolute;
    left: 0;
    right: 0;
    top: var(--hero-collage-offset-y);
    bottom: 0;
    z-index: 2;
  }

  .hero-probbd {
    width: 72%;
    max-width: none;
    z-index: 2;
    filter: drop-shadow(0 24px 60px rgba(0, 0, 0, 0.6));
  }

  .hero-probbd-pos {
    position: absolute;
    right: -20%;
    bottom: calc(-20px * var(--hero-stage-scale));
  }

  /* Panel salidas: % del artboard para mantener orden en cualquier escala */
  .hero-salidas {
    width: 56%;
    max-width: none;
    z-index: 2;
    filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.5));
  }

  .hero-salidas-pos {
    position: absolute;
    left: -22%;
    bottom: calc(-50px * var(--hero-stage-scale));
  }

  .hero-palet {
    width: 60%;
    max-width: none;
    z-index: 2;
    filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.5));
  }

  .hero-palet-pos {
    position: absolute;
    left: 5%;
    bottom: calc(-50px * var(--hero-stage-scale));
  }

  .hero-calendarr {
    width: 22%;
    max-width: none;
    object-fit: contain;
    z-index: 6;
  }

  .hero-calendarr-pos {
    position: absolute;
    top: -25%;
    left: 30%;
  }

  .hero-dates {
    z-index: 5;
  }

  .hero-dates-pos {
    position: absolute;
    left: 30%;
    top: 20%;
    transform: translateY(-50%) scale(calc(0.78 * var(--hero-stage-scale)));
    transform-origin: right center;
  }

  @media (max-width: 1100px) {
    .hero-dates {
      transform: translateY(-50%) scale(calc(0.65 * var(--hero-stage-scale)));
    }
  }

  /* ── Móvil: solo collage sobre fondo ── */
  .hero-mobile {
    display: none;
    width: 100%;
    padding: 72px 0 0;
    box-sizing: border-box;
  }

  .hero-mobile-visual {
    position: relative;
    height: clamp(460px, 108vw, 620px);
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
    overflow: visible;
  }

  .hero-mobile-chevrons {
    position: absolute;
    left: 8%;
    bottom: 12%;
    z-index: 4;
    display: flex;
    flex-direction: column;
    align-items: center;
    pointer-events: none;
    opacity: 0.85;
  }

  .hero-mobile-chevrons .hero-chevron--mobile {
    margin-bottom: -5px;
  }

  .hero-mobile-visual-bg {
    position: absolute;
    inset: -88px 0 0;
    z-index: 0;
    background-image:
      linear-gradient(
        to bottom,
        rgba(100, 100, 100, 0.36) 0%,
        rgba(55, 55, 55, 0.58) 28%,
        rgba(22, 22, 22, 0.88) 68%,
        #000000 100%
      ),
      url('/images/hero-bg-mobile.png');
    background-position: center top;
    background-size: cover;
    background-repeat: no-repeat;
    border-radius: 0 0 18px 18px;
  }

  .hero-mobile-collage {
    position: absolute;
    left: 0;
    right: 0;
    top: 8px;
    bottom: 0;
    z-index: 1;
  }

  .hero-mobile-probbd {
    width: 48%;
    max-width: 320px;
    margin: 0 auto;
    z-index: 3;
    object-fit: contain;
    filter: drop-shadow(0 16px 28px rgba(0, 0, 0, 0.5));
  }

  .hero-mobile-probbd-pos {
    position: absolute;
    left: 0%;
    right: -54%;
    bottom: 35%;
  }

  .hero-mobile-palet {
    width: 50%;
    max-width: none;
    z-index: 2;
    object-fit: contain;
    filter: drop-shadow(0 16px 28px rgba(0, 0, 0, 0.5));
  }

  .hero-mobile-palet-pos {
    position: absolute;
    left: 10%;
    bottom: 24%;
  }

  .hero-mobile-box {
    width: 40%;
    z-index: 2;
    object-fit: contain;
    opacity: 0.98;
  }

  .hero-mobile-box-pos {
    position: absolute;
    left: 2%;
    top: 20%;
  }

  .hero-mobile-salidas {
    width: 50%;
    max-width: 248px;
    z-index: 2;
    filter: drop-shadow(0 12px 24px rgba(0, 0, 0, 0.45));
  }

  .hero-mobile-salidas-pos {
    position: absolute;
    left: 0%;
    top: 0%;
  }

  .hero-mobile-cal {
    width: 24%;
    z-index: 5;
    object-fit: contain;
  }

  .hero-mobile-cal-pos {
    position: absolute;
    left:40%;
    top: 6%;
  }

  .hero-mobile-dates {
    z-index: 5;
  }

  .hero-mobile-dates-pos {
    position: absolute;
    left: 0%;
    top:8%;
    transform: scale(0.42);
    transform-origin: right center;
  }

  .hero-mobile-cta-wrap {
    display: none;
    justify-content: center;
    margin-top: -70px;
    padding: 0 16px 20px;
    position: relative;
    z-index: 10;
  }

  .hero-mobile-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: min(230px, 100%);
    padding: 12px 20px;
    background: linear-gradient(to right, #FF530F, #E84403);
    border-radius: 18px;
    font-family: 'Epilogue', sans-serif;
    font-size: 23px;
    font-weight: 500;
    color: #fff;
    white-space: nowrap;
    transition: opacity 0.2s;
  }

  .hero-mobile-cta:hover {
    opacity: 0.9;
  }

  @media (max-width: 1024px) {
    .hero-desktop {
      min-height: 640px;
    }
  }

  @media (max-width: 768px) {
    .hero-desktop {
      display: none;
    }

    .hero-mobile {
      display: block;
    }

    .hero-mobile-cta-wrap {
      display: flex;
    }

    .hero-mobile-visual-bg {
      background-size: 100% auto;
      background-position: center 4px;
    }
  }
</style>
