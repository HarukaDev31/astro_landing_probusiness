              loading="lazy"
              width="560"
              height="420"
              decoding="async"
            />
          </picture>
          <div class="point-card-media-shade" aria-hidden="true"></div>
        </div>
        <div
          class="point-card-mobile-cta"
          style="position: relative; bottom: 0;"
        >
          <a href="#" class="point-card-btn point-card-btn--free">
            <span class="point-btn-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path
                  d="M12 5v14M5 12h14"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"></path>
              </svg>
            </span>
            Ver recurso gratuito
            <img
              src="/images/arrows.png"
              alt="Arrow right"
              class="point-card-arrow-hint"
            />
          </a>
        </div>
      </article>

      <article
        class="point-card point-card--warm point-card--align-end"
        style="background: url('/images/gradientecard2.png') no-repeat center center; background-size: cover;"
      >
        <div class="point-card-copy">
          <p class="point-card-quote">
            <span class="point-quote-mark" aria-hidden="true">"</span>
            Aún no tengo mi proveedor
            <span class="point-quote-mark" aria-hidden="true">"</span>
          </p>
          <p class="point-card-body">
            Te explicamos cómo conseguir <strong>proveedores confiables</strong
            >.
          </p>
          <div class="point-card-cta-wrap">
            <a href="#" class="point-card-btn point-card-btn--free">
              <span class="point-btn-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                  <path
                    d="M12 5v14M5 12h14"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"></path>
                </svg>
              </span>
              Ver recurso gratuito
            </a>
          </div>
        </div>
        <div class="point-card-media point-card-media--second">
          <picture>
            <source
              media="(max-width: 768px)"
              srcset="/images/point-card-2-mobile.png"
            />
            <img
              src="/images/aunnoproveedor.png"
              alt="Logística y proveedores"
              class="point-card-img point-card-img--second"
              loading="lazy"
              width="560"
              height="420"
              decoding="async"
            />
          </picture>
          <div class="point-card-media-shade" aria-hidden="true"></div>
        </div>
        <div class="point-card-mobile-cta">
          <a href="#" class="point-card-btn point-card-btn--free">
            <span class="point-btn-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path
                  d="M12 5v14M5 12h14"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"></path>
              </svg>
            </span>
            Ver recurso gratuito
          </a>
        </div>
      </article>

      <article class="point-card point-card--align-start third-card">
        <div class="point-card-copy">
          <p class="point-card-quote">
            <span class="point-quote-mark" aria-hidden="true">"</span>
            Listo para importar
            <span class="point-quote-mark" aria-hidden="true">"</span>
          </p>
          <p class="point-card-body">
            Ya tengo la <strong>cotización de mi proveedor</strong>.
          </p>
          <a href="#form" class="point-card-btn point-card-btn--register">
            <span class="point-btn-ellipse" aria-hidden="true">
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M9 18l6-6-6-6"
                  stroke="var(--color-orange-primary)"
                  stroke-width="2.2"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </span>
            <span class="point-register-text">
              Regístrate y te calculamos el costo total de importación.
            </span>
          </a>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .point-section {
    background: var(--color-bg-primary);
    width: 100%;
    overflow-x: clip;
  }

  /* Contenedor principal al 80% del ancho de la vista, centrado */
  .point-wrap {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    max-width: var(--container-width);
    margin-left: auto;
    margin-right: auto;
    padding: 0 clamp(16px, 2vw, 24px);
    box-sizing: border-box;
    overflow-x: clip;
  }

  .point-wrap-deco {
    display: none;
  }

  .point-wrap-deco-mobile {
    display: none;
  }

  @media (min-width: 901px) {
    .point-wrap-deco {
      display: block;
      position: absolute;
      right: -23%;
      bottom: -10%;
      width: min(100%, 720px);
      height: min(100%, 720px);
      max-height: min(92vh, 960px);
      object-fit: contain;
      object-position: bottom right;
      pointer-events: none;
      z-index: 0;
      /**combine color with black of background */
      background: radial-gradient(36.45% 36.45% at 50% 50%, #FF5410 0%, rgba(0, 0, 0, 0.5) 100%);
    }

    .point-header,
    .point-cards {
      position: relative;
      z-index: 1;
    }
  }

  .point-header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 24px 48px;
    margin-bottom: clamp(48px, 6vw, 72px);
  }

  .point-title {
    font-family: var(--font-heading);
    font-size: clamp(40px, 5.2vw, 68px);
    font-weight: 300;
    color: #fff;
    letter-spacing: -0.055em;
    line-height: 0.98;
    max-width: min(420px, 100%);
    margin: 0;
  }

  .point-title-accent {
    background: linear-gradient(90deg, #ff5410 0%, #ff733b 72%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .point-desc {
    font-family: var(--font-body);
    font-size: clamp(17px, 1.65vw, 20px);
    font-weight: 400;
    color: rgba(255, 255, 255, 0.88);
    max-width: 380px;
    text-align: right;
    line-height: 1.55;
    margin: 0;
  }

  .point-desc strong {
    font-weight: 600;
    color: #fff;
  }

  .point-cards {
    display: flex;
    flex-direction: column;
    gap: clamp(40px, 4vw, 50px);
    width: 100%;
    align-items: stretch;
    padding-bottom: 5em;
  }

  /* Tarjeta no ocupa todo el ancho del contenedor 80% */
  .point-card--align-start {
    margin-right: auto;
    margin-left: 0;
    width: min(100%, 92%);
  }

  .point-card--align-end {
    margin-left: auto;
    margin-right: 0;
    width: min(100%, 92%);
  }

  /* Impares: texto | imagen. Pares: imagen | texto (intercalado visual) */
  .point-card {
    display: grid;
    align-items: stretch;
    min-height: clamp(400px, 34vw, 380px);
    border-radius: var(--radius-card-large);
    overflow: hidden;

    box-shadow:
      0 0 0 1px rgba(255, 83, 15, 0.06),
      0 28px 56px rgba(0, 0, 0, 0.55),
      0 0 80px -20px rgba(255, 83, 15, 0.15);

    grid-template-columns: minmax(0, 1fr) minmax(300px, 47%);
    width: max(350px, 60%);
  }
  /**max-width: 769px */
  @media (max-width: 769px) {
    .point-card {
      padding: 1.5em 1em;
    }
  }
  .point-card--align-start .point-card-copy {
    grid-column: 1;
  }

  .point-card--align-start .point-card-media {
    grid-column: 2;
  }

  .point-card--align-end {
    grid-template-columns: minmax(300px, 47%) minmax(0, 1fr);
  }

  .point-card--align-end .point-card-media {
    grid-column: 2;
  }

  .point-card--align-end .point-card-copy {
    grid-column: 1;
  }

  .point-card--warm .point-card-body {
    color: rgba(255, 255, 255, 0.95);
  }

  .point-card--warm .point-card-media-shade {
    
  }

  .point-card-copy {
    padding: clamp(38px, 5.2vw, 58px) clamp(28px, 4vw, 48px)
      clamp(38px, 5.2vw, 58px) clamp(32px, 4vw, 56px);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: clamp(14px, 2vw, 22px);
    min-width: 0;
    width: 100%;
  }

  .point-card-media {
    position: relative;
    min-height: 260px;
    overflow: hidden;
  }

  .point-card-img {
    display: block;
    width: 100%;
    height: 100%;
    max-width: none;
    min-height: 100%;
    object-fit: cover;
    object-position: center center;
  }

  .point-card-media-shade {
    position: absolute;
    inset: 0;
    pointer-events: none;
    
  }

  .point-card-media--second picture {
    display: block;
    width: 100%;
    height: 100%;
  }

  .point-card--warm .point-card-media-shade {
    
  }

  .point-card-quote {
    font-family: var(--font-body, "Epilogue", sans-serif);
    font-size: clamp(20px, 2.35vw, 31px);
    font-weight: 300;
    color: #fff;
    line-height: 1.06;
    letter-spacing: -0.03em;
    margin: 0;
  }

  /* Baja un poco el título en cards 1 y 2; la 3ra se mantiene igual */
  .point-card:not(.third-card) .point-card-quote {
    font-size: clamp(20px, 2.05vw, 28px);
  }

  .point-quote-mark {
    font-weight: 300;
    font-style: italic;
    font-family: var(--font-heading);
  }

  .point-card-body strong {
    color: #fff;
    font-weight: 600;
    font-family: var(--font-body);
  }

  .point-card-body {
    font-family: var(--font-body, "Epilogue", sans-serif);
    font-size: clamp(16px, 1.5vw, 19px);
    font-weight: 300;
    color: rgba(255, 255, 255, 0.86);
    line-height: 1.5;
    margin: 0;
    max-width: 26rem;
  }

  .point-card-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: 6px;
    padding: 14px 22px 14px 18px;
    width: 100%;
    min-height: 52px;
    border-radius: 14px;
    border: 0.5px solid #ff6a29;
    font-family: var(--font-body, "Epilogue", sans-serif);
    font-size: 18px;
    line-height: 1.2;
    text-align: center;
    font-weight: 300;
    color: #fff;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      filter 0.2s ease;
    align-self: flex-start;
    justify-content: center;
    background: linear-gradient(
      90deg,
      #ff5410 0%,
      #ff733b 46.49%,
      #ff5410 100%
    );
    box-shadow: 0 1px 18.4px 12px rgba(255, 106, 41, 0.18);
  }

  .point-btn-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 8px;
    flex-shrink: 0;
    align-self: center;
  }

  .point-card-btn--register {
    flex-wrap: nowrap;
    align-items: center;
    max-width: 90%;
    padding: 12px 20px 12px 14px;
    gap: 14px;
    border-radius: 14px;
    text-align: center;
  }

  .point-register-text {
    font-family: var(--font-body, "Epilogue", sans-serif);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    font-size: 15px;
    font-weight: 300;
    line-height: 1.35;
    max-width: 17rem;
    text-align: center;
  }

  .point-btn-ellipse {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 999px;
    background: white;
    color: var(--color-orange-primary);
    stroke: var(--color-orange-primary) !important;
    stroke-width: 2px;
    flex-shrink: 0;
    align-self: center;
  }

  .point-card-btn:hover {
    transform: translateY(-2px);
    filter: brightness(1.04);
  }

  .point-card-btn:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 3px;
  }

  .point-card-mobile-cta {
    display: none;
  }

  .point-card-media--first .point-card-media-shade {
    background: none;
  }

  .point-card-media--first {
    position: relative;
  }

  .point-card-media--first picture {
    display: contents;
  }

  /* Desktop: caja pegada a esquina inferior izquierda del bloque de imagen (como referencia) */
  .point-card-img--first {
    position: absolute;
    right: -0%;
    z-index: 9;
    bottom: 0%;
    width: 350px;
    height: 350px;
    max-height: 100%;
    object-fit: contain;
    object-position: left bottom;
  }

  @media (max-width: 769px) {
    .point-card-img--first {
      left: 0;
      right: auto;
      bottom: 0;
      transform: none;
      object-position: left bottom;
    }
  }

  @media (max-width: 900px) {
    .point-wrap {
      width: min(92%, 100%);
      padding: 0 16px;
    }

    .point-desc {
      text-align: right;
      max-width: none;
    }

    .point-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .point-card,
    .point-card--align-end {
      grid-template-columns: 1fr;
      min-height: unset;
      width: min(100%, 360px) !important;
      margin-left: auto !important;
      margin-right: auto !important;
      border-radius: 14px;
    }

    .point-card-media {
      grid-column: auto !important;
      grid-row: 2;
      min-height: 136px;
      max-height: 170px;
      aspect-ratio: 16 / 8;
      position: relative;
    }

    .point-card-copy {
      grid-column: auto !important;
      grid-row: 1;
      justify-content: flex-start;
      gap: 10px;
      padding: 0 14px;
    }

    .point-card-img {
      min-height: 136px;
      max-height: 170px;
      object-position: center bottom;
    }

    .point-card-media-shade {
     
    }

    .point-card-quote {
      font-size: clamp(28px, 8vw, 34px);
      line-height: 1.02;
    }

    .point-card:not(.third-card) .point-card-quote {
      font-size: clamp(24px, 7vw, 30px);
    }

    .point-card-body {
      font-size: 12px;
      line-height: 1.35;
      max-width: 220px;
    }

    .point-card-btn {
      width: auto;
      min-height: 44px;
      padding: 7px 12px;
      border-radius: 14px;
      font-size: 14px;
      gap: 6px;
      margin-top: 2px;
    }

    .point-btn-icon {
      width: 20px;
      height: 20px;
    }

    .point-card-cta-wrap {
      width: 100%;
      position: relative;
    }

    .point-card-arrow-hint {
      position: absolute;
      top: 30px;
      right: -80px;
    }

    .point-card--warm {
      box-shadow:
        0 28px 56px rgba(0, 0, 0, 0.55),
        0 0 80px -20px rgba(255, 83, 15, 0.15);
    }

    .point-card-media--second picture,
    .point-card-media--second img,
    .point-card-img--second {
      border: none !important;
      outline: none !important;
      box-shadow: none !important;
    }

    /* Card 1: caja centrada abajo (no pegada a la esquina como en desktop) */
    .point-card-media--first {
      display: flex;
      justify-content: center;
      align-items: flex-end;
      padding: 0 clamp(10px, 3vw, 16px) clamp(6px, 2vw, 12px);
      box-sizing: border-box;
      aspect-ratio: auto;
      position: relative;
    }

    .point-card-media--first .point-card-img--first {
      position: relative;
      left: auto;
      right: auto;
      bottom: auto;
      transform: none;
      width: min(82%, 280px);
      height: auto;
      max-height: 100%;
      object-fit: contain;
      object-position: center bottom;
    }
  }

  @media (max-width: 480px) {
    .point-register-text {
      font-size: 13px;
      max-width: none;
    }

    .point-card-btn--register {
      flex-wrap: wrap;
    }
  }

  .first-card {
    border-radius: 20px;
    background: radial-gradient(
      303.55% 219.67% at 107.62% 128.64%,
      #ff5410 0%,
      rgba(255, 84, 16, 0.73) 28.88%,
      rgba(255, 84, 16, 0.15) 43.48%,
      rgba(255, 84, 16, 0.11) 57.19%,
      rgba(255, 84, 16, 0) 100%
    );
    background-blend-mode: plus-darker, normal;
    backdrop-filter: blur(2px);
  }
  .third-card {
    background: url("/images/listoimportar.png") no-repeat center center;
    background-size: cover;
    border: none !important;
  }
  /**mobile third card min height 300px */
  @media (max-width: 768px) {
    .point-wrap-deco-mobile {
      display: block;
      position: absolute;
      top: -28vh;
      left: 0;
      width: min(319px, 82vw);
      height: auto;
      pointer-events: none;
      z-index: 0;
      opacity: 0.9;
    }

    .point-cards {
      gap: 12px;
      padding-bottom: 1em;
    }

    .point-wrap {
      width: 92%;
      padding: 0;
    }

    .point-card--align-start,
    .point-card--align-end {
      width: min(100%, 330px) !important;
      min-height: 390px;
      max-height: 390px;
      position: relative;
    }

    .point-card-quote {
      font-size: clamp(24px, 7.2vw, 32px);
      line-height: 1.04;
    }

    .point-card:not(.third-card) .point-card-quote {
      font-size: clamp(22px, 6.5vw, 29px);
    }

    .point-card-body {
      font-size: 14px;
      line-height: 1.45;
    }

    .point-card-copy {
      gap: 12px;
      padding-top: 0;
    }

    .third-card {
      min-height: 390px;
      border-radius: 24px !important;
      border: 0.5px solid #fff !important;
      display: flex;
      align-items: flex-start;
      /* Imagen arriba, radial en medio, fondo base abajo */
      background-image:
        url("/images/point-card-3-mobile.png"),
        linear-gradient(
          90deg,
          rgba(255, 84, 16, 0.9) 0%,
          rgba(255, 84, 16, 0.55) 28%,
          rgba(255, 84, 16, 0.18) 48%,
          rgba(0, 0, 0, 0.72) 72%,
          rgba(0, 0, 0, 0.9) 100%
        ),
        linear-gradient(180deg, #2b2b2b 0%, #1f1f1f 100%);
      background-size: 76% auto, cover, cover;
      background-position: center bottom 20px, center center, center center;
      background-repeat: no-repeat, no-repeat, no-repeat;
    }

    .third-card .point-card-copy {
      padding-bottom: 176px;
    }

    .third-card .point-card-quote {
      font-size: clamp(20px, 5.8vw, 20px);
    }

    .point-card-media {
      min-height: 165px;
      max-height: 210px;
      aspect-ratio: 16 / 9;
      margin: 0 auto;
    }

    .point-card-img {
      min-height: 165px;
      max-height: 210px;
    }

    .point-card-btn {
      position: static;
      transform: none;
      width: auto;
      max-width: max-content;
