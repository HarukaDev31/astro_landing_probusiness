<section
  class="point-section"
  aria-labelledby="point-heading"
  style="position: relative;"
>
  <div
    class="point-wrap-deco"
    style="background: radial-gradient(36.45% 36.45% at 50% 50%, #FF5410 0%, rgba(255, 106, 41, 0.00) 100%);"
  >
  </div>
  <svg
    class="point-wrap-deco-mobile"
    width="319"
    height="773"
    viewBox="0 0 319 773"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <rect
      x="-105.551"
