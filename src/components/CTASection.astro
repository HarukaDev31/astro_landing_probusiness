---
/** CTA — fondo blanco, ondas en CSS, iconos PNG (Figma) */
const waHref = 'https://wa.me/51999999999';
---

<section class="cta-section" aria-labelledby="cta-heading">
  <div class="cta-visual">
    <!-- Pocas ondas concéntricas (solo código) -->
    <div class="cta-waves" aria-hidden="true">
      <div class="cta-waves-layer"></div>
    </div>

    <h2 id="cta-heading" class="cta-heading">
      <span class="cta-heading-line cta-heading-line--muted">¿Listo/a para</span>
      <span class="cta-heading-line cta-heading-line--accent">¿importar?</span>
    </h2>

    <div class="cta-stage">
      <span class="cta-float cta-float--chat" aria-hidden="true">
        <img
          src="/images/cta-icon-chat.png"
          alt=""
          class="cta-float-png cta-float-png--chat"
          width="88"
          height="88"
          loading="lazy"
          decoding="async"
        />
      </span>

      <span class="cta-float cta-float--pin" aria-hidden="true">
        <img
          src="/images/cta-icon-pin.png"
          alt=""
          class="cta-float-png cta-float-png--pin"
          width="76"
          height="92"
          loading="lazy"
          decoding="async"
        />
      </span>

      <div class="cta-float cta-float--plane" aria-hidden="true">
        <img
          src="/images/cta-float-plane.png"
          alt=""
          class="cta-float-png cta-float-png--circle"
          width="140"
          height="140"
          loading="lazy"
          decoding="async"
        />
      </div>

      <div class="cta-float cta-float--pallets" aria-hidden="true">
        <img
          src="/images/cta-float-pallets.png"
          alt=""
          class="cta-float-png cta-float-png--circle"
          width="140"
          height="140"
          loading="lazy"
          decoding="async"
        />
      </div>

      <span class="cta-float cta-float--truck" aria-hidden="true">
        <img
          src="/images/cta-truck.png"
          alt=""
          class="cta-float-png cta-float-png--truck"
          width="88"
          height="72"
          loading="lazy"
          decoding="async"
        />
      </span>

      <div class="cta-hero" style="position: relative;">
        <div class="cta-hero-ring">
          <img
            src="/images/chaleco.png"
            alt="Asesora Pro Business con chaleco y casco"
            class="cta-hero-img"
            width="400"
            height="400"
            loading="lazy"
            decoding="async"
          />
          
        </div>
        <img
            src="/images/ct_msg1.png"
            alt="Asesora Pro Business con chaleco y casco"
            style="position: absolute; top: 70px; right: -250px;"
            class="cta-hero-img"
            width="400"
            height="400"
            loading="lazy"
            decoding="async"
          />
      </div>

      <!-- Globo: solapa el círculo por la derecha; pico hacia la persona (izquierda del globo) -->
   
    </div>

    <div class="cta-actions">
      <a href={waHref} target="_blank" rel="noopener noreferrer" class="cta-btn-pill">
        Escríbenos al WhatsApp
      </a>
    </div>
  </div>
</section>

<style>
  .cta-section {
    --cta-green: #4ade80;
    --cta-green-ring: rgba(74, 222, 128, 0.38);
    --cta-wave-step: 76px; /* ancho entre anillos → pocas ondas visibles */
    --cta-wave-center-x: 56%;
    --cta-wave-center-y: 40%;
    background: #fff;
    padding: clamp(56px, 8vw, 100px) clamp(20px, 4vw, 40px) clamp(64px, 10vw, 120px);
    overflow: hidden;
  }

  .cta-visual {
    position: relative;
    max-width: 920px;
    margin: 0 auto;
    min-height: min(72vw, 560px);
    background: #fff;
    isolation: isolate;
  }

  /* Ondas verdes finas, solo código */
  .cta-waves {
    position: absolute;
    inset: -25% -35% -20% -35%;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
    mask-image: radial-gradient(
      ellipse 88% 82% at var(--cta-wave-center-x) var(--cta-wave-center-y),
      #000 0%,
      #000 48%,
      transparent 82%
    );
    -webkit-mask-image: radial-gradient(
      ellipse 88% 82% at var(--cta-wave-center-x) var(--cta-wave-center-y),
      #000 0%,
      #000 48%,
      transparent 82%
    );
  }

  .cta-waves-layer {
    position: absolute;
    inset: 0;
    background-color: #fff;
    background-image: repeating-radial-gradient(
      circle at var(--cta-wave-center-x) var(--cta-wave-center-y),
      transparent 0,
      transparent calc(var(--cta-wave-step) - 1px),
      var(--cta-green-ring) calc(var(--cta-wave-step) - 1px),
      var(--cta-green-ring) var(--cta-wave-step)
    );
    opacity: 0.85;
  }

  .cta-heading {
    position: relative;
    z-index: 2;
    margin: 0 0 clamp(28px, 5vw, 40px);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.12em;
    font-family: 'Sora', var(--font-heading), system-ui, sans-serif;
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 400;
    letter-spacing: -0.04em;
    line-height: 1.05;
  }

  .cta-heading-line {
    display: block;
  }

  .cta-heading-line--muted {
    color: #0a0a0a;
  }

  .cta-heading-line--accent {
    color: var(--cta-green);
    text-transform: lowercase;
  }

  .cta-stage {
    position: relative;
    z-index: 2;
    width: min(100%, 520px);
    aspect-ratio: 1;
    margin: 0 auto clamp(72px, 12vw, 112px);
    display: grid;
    place-items: center;
    overflow: visible;
  }

  .cta-hero {
    position: relative;
    width: min(62%, 280px);
    z-index: 3;
  }

  .cta-hero-ring {
    position: relative;
    border-radius: 50%;
    background: var(--cta-green);
    border: 5px solid #fff;
    box-shadow:
      0 0 0 1px rgba(0, 0, 0, 0.06),
      0 8px 32px rgba(0, 0, 0, 0.12),
      0 0 28px rgba(74, 222, 128, 0.35);
    aspect-ratio: 1;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }

  .cta-hero-img {
    width: 88%;
    height: auto;
    object-fit: contain;
    object-position: bottom center;
    display: block;
    margin-bottom: -4%;
  }

  .cta-float {
    position: absolute;
    z-index: 2;
    pointer-events: none;
    line-height: 0;
  }

  .cta-float-png {
    display: block;
    width: auto;
    height: auto;
    max-width: min(22vw, 100px);
    object-fit: contain;
  }

  .cta-float-png--chat {
    max-width: min(24vw, 108px);
    transform: rotate(8deg);
    filter: drop-shadow(0 10px 18px rgba(0, 0, 0, 0.18));
  }

  .cta-float-png--pin {
    max-width: min(20vw, 88px);
    transform: rotate(-10deg);
    filter: drop-shadow(0 10px 18px rgba(0, 0, 0, 0.18));
  }

  .cta-float-png--circle {
    max-width: min(30vw, 142px);
    border-radius: 50%;
    filter: drop-shadow(0 0 20px rgba(255, 255, 255, 0.95)) drop-shadow(0 12px 24px rgba(0, 0, 0, 0.14));
  }

  .cta-float-png--truck {
    max-width: min(26vw, 96px);
    transform: rotate(14deg);
    filter: drop-shadow(0 10px 18px rgba(0, 0, 0, 0.18));
  }

  .cta-callout {
    position: absolute;
    /* Centrado en altura con el círculo; hacia la derecha para solapar la mitad derecha del avatar */
    left: clamp(38%, 42vw, 46%);
    top: 50%;
    transform: translateY(-50%);
    z-index: 5;
    width: min(248px, 52%);
    max-width: 260px;
    padding: 20px 22px 22px;
    border-radius: 18px;
    background: #262626;
    background: linear-gradient(180deg, #2e2e2e 0%, #262626 45%, #1f1f1f 100%);
    color: #fff;
    box-shadow:
      0 20px 48px rgba(0, 0, 0, 0.18),
      0 8px 16px rgba(0, 0, 0, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.07);
  }

  /* Pico en el borde izquierdo, apuntando hacia el centro (la persona) */
  .cta-callout::before {
    content: '';
    position: absolute;
    left: -11px;
    top: 50%;
    transform: translateY(-50%);
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 10px 12px 10px 0;
    border-color: transparent #2e2e2e transparent transparent;
    filter: drop-shadow(-2px 0 1px rgba(0, 0, 0, 0.06));
  }

  .cta-callout-line {
    margin: 0;
    font-family: 'Epilogue', var(--font-body), system-ui, sans-serif;
    font-size: clamp(0.9375rem, 2.1vw, 1.0625rem);
    font-weight: 400;
    line-height: 1.45;
    text-align: left;
    letter-spacing: 0.01em;
  }

  .cta-callout-line + .cta-callout-line {
    margin-top: 6px;
  }

  .cta-callout-line strong {
    font-weight: 700;
  }

  .cta-callout-line--with-icon {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
  }

  .cta-callout-icon {
    display: block;
    width: 22px;
    height: 22px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .cta-float--chat {
    top: 2%;
    left: -4%;
  }

  .cta-float--pin {
    top: 0%;
    right: 2%;
  }

  .cta-float--plane {
    bottom: 16%;
    left: -12%;
  }

  .cta-float--pallets {
    right: -12%;
    top: 34%;
  }

  .cta-float--truck {
    bottom: -6%;
    right: 6%;
    z-index: 4;
  }

  .cta-actions {
    position: relative;
    z-index: 3;
    display: flex;
    justify-content: center;
    margin-top: clamp(8px, 2vw, 20px);
  }

  .cta-btn-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 18px clamp(32px, 6vw, 56px);
    border-radius: 999px;
    background: var(--cta-green);
    color: #000;
    font-family: 'Epilogue', var(--font-body), system-ui, sans-serif;
    font-size: clamp(1rem, 2.4vw, 1.25rem);
    font-weight: 600;
    text-decoration: none;
    box-shadow: 0 12px 40px rgba(74, 222, 128, 0.35);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      background 0.2s ease;
  }

  .cta-btn-pill:hover {
    transform: translateY(-3px);
    background: #86efac;
    box-shadow: 0 16px 48px rgba(74, 222, 128, 0.45);
  }

  .cta-btn-pill:focus-visible {
    outline: 2px solid #16a34a;
    outline-offset: 4px;
  }

  @media (max-width: 640px) {
    .cta-stage {
      width: min(100%, 400px);
      margin-bottom: clamp(24px, 8vw, 40px);
      aspect-ratio: auto;
      min-height: min(88vw, 380px);
      padding-bottom: clamp(120px, 36vw, 160px);
    }

    .cta-float--chat {
      left: -2%;
    }

    .cta-float--pin {
      right: -2%;
    }

    .cta-float--plane {
      left: -6%;
      bottom: 20%;
    }

    .cta-float--pallets {
      right: -8%;
    }

    .cta-float--truck {
      right: 2%;
      bottom: 8%;
    }

    /* Debajo del círculo, centrado; pico arriba hacia el avatar */
    .cta-callout {
      left: 50%;
      top: auto;
      bottom: clamp(4px, 2vw, 12px);
      transform: translateX(-50%);
      width: min(300px, 94%);
      max-width: none;
    }

    .cta-callout::before {
      left: 50%;
      top: -12px;
      transform: translateX(-50%);
      border-width: 0 10px 14px 10px;
      border-color: transparent transparent #2e2e2e transparent;
    }
  }
</style>
