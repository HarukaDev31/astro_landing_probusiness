---
/**
 * Figma: node 4024:184 — barra 70px, fondo #000, texto centrado Sora 16px
 * (bold + regular, mayúsculas). Sin icono ni borde inferior.
 */
---

<div class="announcement-bar">
  <div class="announcement-inner">
    <img src="https://cdn.probusiness.pe/landingconsolidado/images/alert.webp" alt="Alerta" class="announcement-logo" width="30" height="30" />
    <div class="announcement-marquee" aria-label="El contenedor cierra en menos de una semana — aún estás a tiempo de asegurar tu espacio">
      <p class="announcement-text announcement-text--marquee">
        <span class="announcement-text-content">
          <span class="announcement-text-strong">Une fuerza con otros importadores</span><span
            class="announcement-text-sep"
            aria-hidden="true"> — </span
          ><span class="announcement-text-regular">aún estás a tiempo de asegurar tu espacio</span>
        </span>
        <span class="announcement-text-content announcement-text-content--clone" aria-hidden="true">
          <span class="announcement-text-strong">Une fuerza con otros importadores</span><span
            class="announcement-text-sep"
            aria-hidden="true"> — </span
          ><span class="announcement-text-regular">aún estás a tiempo de asegurar tu espacio</span>
        </span>
      </p>
    </div>
  </div>
</div>

<style>
  @keyframes announcement-marquee-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(calc(-50% - var(--announcement-gap) / 2));
    }
  }

  .announcement-bar {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 70px;
    padding: 0 clamp(16px, 2.86vw, 33px);
    background: #000;
    box-sizing: border-box;
  }

  .announcement-inner {
    width: 100%;
    max-width: 1152px;
    margin-inline: auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }

  .announcement-marquee {
    min-width: 0;
  }

  .announcement-text {
    margin: 0;
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 16px;
    line-height: normal;
    font-weight: 700;
    color: #fff;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .announcement-text--marquee {
    display: block;
  }

  .announcement-text-content--clone {
    display: none;
  }

  .announcement-text-strong {
    font-weight: 700;
  }

  .announcement-text-sep {
    font-weight: 700;
  }

  .announcement-text-regular {
    font-weight: 300;
  }

  @media (max-width: 768px) {
    .announcement-bar {
      min-height: 0;
      padding-block: 14px;
    }

    .announcement-inner {
      justify-content: flex-start;
    }

    .announcement-marquee {
      flex: 1;
      overflow: hidden;
    }

    .announcement-text {
      font-size: 12px;
      letter-spacing: 0.04em;
      line-height: 1.2;
      white-space: nowrap;
    }

    .announcement-text--marquee {
      --announcement-gap: 44px;
      display: inline-flex;
      align-items: center;
      gap: var(--announcement-gap);
      min-width: max-content;
      will-change: transform;
      animation: announcement-marquee-scroll 14s linear infinite;
    }

    .announcement-text-content {
      display: inline-flex;
      align-items: center;
      white-space: nowrap;
    }

    .announcement-text-content--clone {
      display: inline-flex;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .announcement-text--marquee {
      animation: none;
    }
  }

  @media (max-width: 400px) {
    .announcement-text {
      font-size: 11px;
    }
  }
</style>
