---
/**
 * Figma: node 4024:184 — barra 70px, fondo #000, texto centrado Sora 16px
 * (bold + regular, mayúsculas). Sin icono ni borde inferior.
 */
---

<div class="announcement-bar">
  <div class="announcement-inner">
    <img src="/images/alert.png" alt="Alerta" class="announcement-logo" width="30" height="30" />
    <p class="announcement-text">
      <span class="announcement-text-strong">El contenedor cierra en menos de una semana</span><span
        class="announcement-text-sep"
        aria-hidden="true"> — </span
      ><span class="announcement-text-regular">aún estás a tiempo de asegurar tu espacio</span>
    </p>
  </div>
</div>

<style>
  .announcement-bar {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 70px;
    padding: 0 clamp(16px, 2.86vw, 33px);
    background: #000;
    box-sizing: border-box;
  }

  .announcement-inner {
    width: 100%;
    max-width: 1152px;
    margin-inline: auto;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .announcement-text {
    margin: 0;
    font-family: 'Sora', system-ui, sans-serif;
    font-size: 16px;
    line-height: normal;
    font-weight: 700;
    color: #fff;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .announcement-text-strong {
    font-weight: 700;
  }

  .announcement-text-sep {
    font-weight: 700;
  }

  .announcement-text-regular {
    font-weight: 300;
  }

  @media (max-width: 768px) {
    .announcement-bar {
      min-height: 0;
      padding-block: 14px;
    }

    .announcement-text {
      font-size: 12px;
      letter-spacing: 0.04em;
      line-height: 1.35;
    }
  }

  @media (max-width: 400px) {
    .announcement-text {
      font-size: 11px;
    }
  }
</style>
