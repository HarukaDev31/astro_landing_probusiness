---
/**
 * HeroMessaging — una columna: título, lead y video comparten el mismo inicio horizontal
 * (borde izquierdo del .container). Sin centrar el bloque respecto al video.
 */
---

<section class="hero-msg" aria-label="Importación desde China con Pro Business">
  <div class="hero-msg-inner container">
    <div class="hm-block">
      <div class="hm-copy">
        <div class="hm-head">
          <h1 class="hm-title">
            <span class="hm-title-line">Importa desde </span>
            <span class="hm-title-line hm-title-line--mid"><strong>China sin</strong></span>
            <span class="hm-title-line hm-title-line--cta-row">
              <span class="hm-title-accent">complicaciones</span>
              <a href="#form" class="hm-pill-arrow" aria-label="Cotizar mi importación">
                <svg class="hm-pill-arrow-icon" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path
                    d="M0.290807 22.705L10.2906 32.7048C10.6498 33.1243 11.2811 33.1732 11.7005 32.8139C12.12 32.4547 12.1689 31.8234 11.8096 31.4039C11.7761 31.3648 11.7396 31.3283 11.7005 31.2949L3.41071 22.995L43.0001 22.995C43.5523 22.995 44 22.5473 44 21.995C44 21.4427 43.5523 20.995 43.0001 20.995L3.41071 20.995L11.7005 12.7052C12.12 12.346 12.1689 11.7147 11.8096 11.2953C11.4503 10.8758 10.8191 10.8269 10.3996 11.1862C10.3605 11.2197 10.324 11.2562 10.2906 11.2953L0.290719 21.2951C-0.0969381 21.685 -0.0969381 22.3149 0.290807 22.705Z"
                    fill="black"
                  />
                </svg>
              </a>
            </span>
          </h1>
        </div>

        <p class="hm-lead">
          <span class="hm-lead-regular">Acompañamiento 360</span> desde el pago al proveedor hasta la entrega en tus manos en Perú.
        </p>
      </div>

      <div
        class="hm-media"
        data-hm-media
        role="region"
        aria-label="Video: más de 100 mil proveedores"
      >
        <video
          class="hm-media-video"
          controls
          loop
          playsinline
          webkit-playsinline
          preload="auto"
          aria-label="Video: mercado y proveedores en China"
          width="1920"
          height="1080"
        >
          <source src="/videos/LANDING_CC_web_1080p.mp4" type="video/mp4" />
        </video>
        <div class="hm-media-shade" aria-hidden="true"></div>
        <div class="hm-media-preview" data-hm-media-preview>
          <button
            type="button"
            class="hm-media-play-btn"
            data-hm-media-play
            aria-label="Reproducir video"
          >
            <svg width="52" height="52" viewBox="0 0 24 24" fill="white" aria-hidden="true">
              <path d="M8 5v14l11-7z"></path>
            </svg>
          </button>
        </div>
        <button
          type="button"
          class="hm-media-unmute"
          data-hm-media-unmute
          hidden
          aria-label="Activar sonido del video"
        >
          <svg class="hm-media-unmute-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path
              d="M11 5L6 9H2v6h4l5 4V5zM15.54 8.46a5 5 0 010 7.07m2.83-9.9a9 9 0 010 12.73"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
          <span class="hm-media-unmute-text">Activar sonido</span>
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll("[data-hm-media]").forEach((root) => {
    const preview = root.querySelector("[data-hm-media-preview]");
    const playBtn = root.querySelector("[data-hm-media-play]");
    const unmuteBtn = root.querySelector("[data-hm-media-unmute]");
    const video = root.querySelector(".hm-media-video");
    if (!(preview instanceof HTMLElement) || !(video instanceof HTMLVideoElement))
      return;

    /** Autoplay con sonido suele estar bloqueado; si el vídeo va mute, mostramos botón para activar audio con un clic. */
    const syncUnmuteBtn = () => {
      if (!(unmuteBtn instanceof HTMLElement)) return;
      const show = !video.paused && video.muted && preview.hidden;
      unmuteBtn.hidden = !show;
    };

    const reveal = () => {
      preview.hidden = true;
      root.classList.add("hm-media--playing");
      syncUnmuteBtn();
    };

    const showPreview = () => {
      preview.hidden = false;
      root.classList.remove("hm-media--playing");
      syncUnmuteBtn();
    };

    try {
      video.playsInline = true;
    } catch {
      /* noop */
    }

    const playUnmuted = () => {
      video.muted = false;
      video.defaultMuted = false;
      video.removeAttribute("muted");
      video.volume = 1;
      return video.play();
    };

    /**
     * 1) Con sonido. 2) Si el navegador bloquea, autoplay muteado (suele permitirse).
     * Varios disparadores (microtask, canplay, timeout) por si `canplay` ya pasó antes del script.
     */
    const tryAutoplay = () => {
      if (!video.paused) return;

      const p = playUnmuted();
      if (p === undefined) return;
      p.then(() => reveal()).catch(() => {
        video.muted = true;
        video.defaultMuted = true;
        const p2 = video.play();
        if (p2 === undefined) return;
        p2
          .then(() => reveal())
          .catch(() => showPreview());
      });
    };

    const scheduleAutoplay = () => {
      queueMicrotask(() => tryAutoplay());
      video.addEventListener("canplay", () => tryAutoplay(), { once: true });
      window.setTimeout(() => {
        if (video.paused) tryAutoplay();
      }, 600);
    };

    const playOnUserGesture = () => {
      reveal();
      const p = playUnmuted();
      if (p !== undefined) p.catch(() => showPreview());
    };

    if (playBtn instanceof HTMLElement) {
      playBtn.addEventListener("click", (e) => {
        e.stopPropagation();
        playOnUserGesture();
      });
    }

    if (unmuteBtn instanceof HTMLElement) {
      unmuteBtn.addEventListener("click", (e) => {
        e.stopPropagation();
        video.muted = false;
        video.defaultMuted = false;
        video.removeAttribute("muted");
        video.volume = 1;
        const p = video.play();
        if (p !== undefined) p.catch(() => {});
        syncUnmuteBtn();
      });
    }

    video.addEventListener("volumechange", syncUnmuteBtn);

    preview.addEventListener("click", (e) => {
      if (preview.hidden) return;
      if (e.target instanceof Element && e.target.closest("[data-hm-media-play]"))
        return;
      playOnUserGesture();
    });

    video.addEventListener("play", () => {
      reveal();
    });

    video.addEventListener("ended", () => {
      showPreview();
    });

    scheduleAutoplay();
  });
</script>

<style>
  .hero-msg {
    background: #000;
    padding: 100px 0;
    position: relative;
    z-index: 2;
    width: 80%;
    margin: 0 auto;
  }

  .hero-msg-inner {
    max-width: var(--container-width, 1152px);
  }

  .hm-block {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    max-width: 100%;
    width: 100%;
  }

  .hm-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    width: 100%;
  }

  .hm-head {
    display: flex;
    justify-content: flex-start;
    width: 100%;
  }

  .hm-title {
    font-family: var(--font-body, 'Epilogue', sans-serif);
    font-size: clamp(36px, 6.5vw, 56px);
    font-weight: 300;
    color: #fff;
    line-height: 1.05;
    letter-spacing: -0.035em;
    margin: 0;
    text-align: left;
    width: max-content;
    max-width: 100%;
  }

  .hm-title-line {
    display: block;
  }

  .hm-title-line--mid {
    font-weight: 300;
    color: #fff;
  }

  .hm-title-line--mid strong {
    font-weight: 300;
  }

  /* Tercera línea: "complicaciones" y pastilla en la misma fila, centrados en altura */
  .hm-title-line--cta-row {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px 14px;
    margin-top: 0.02em;
  }

  .hm-title-accent {
    color: #ff5410;
    font-weight: 300;
    line-height: 1;
  }

  /* Elipse horizontal (cápsula), no círculo */
  .hm-pill-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: auto;
    min-width: 72px;
    height: 40px;
    padding: 0 12px;
    background: linear-gradient(to right, #ff5410, #ff6a2e);
    border-radius: 999px;
    text-decoration: none;
    box-shadow: 0 6px 20px rgba(255, 84, 16, 0.35);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .hm-pill-arrow:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 26px rgba(255, 84, 16, 0.45);
  }

  .hm-pill-arrow-icon {
    display: block;
    flex-shrink: 0;
    width: 26px;
    height: 26px;
  }

  .hm-lead {
    font-family: var(--font-body, 'Epilogue', sans-serif);
    font-size: clamp(15px, 2.2vw, 18px);
    font-weight: 400;
    line-height: 1.55;
    color: #fff;
    margin: 20px 0 0;
    max-width: min(100%, 360px);
    text-align: justify ;
    width: 100%;
  }

  .hm-lead-strong {
    font-weight: 600;
  }

  .hm-media {
    position: relative;
    display: block;
    margin-top: clamp(40px, 7vw, 64px);
    margin-left: 0;
    margin-right: 0;
    width: 100%;
    max-width: 100%;
    align-self: stretch;
    border-radius: clamp(22px, 3vw, 32px);
    overflow: hidden;
    aspect-ratio: 16 / 10;
    color: inherit;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.45);
    background: #000;
  }

  @media (min-width: 900px) {
    .hm-media {
      aspect-ratio: 16 / 9;
    }
  }

  .hm-media-video {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    display: block;
  }

  .hm-media-shade {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.15) 0%,
      transparent 40%,
      transparent 58%,
      rgba(0, 0, 0, 0.55) 100%
    );
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .hm-media--playing .hm-media-shade {
    opacity: 1;
  }

  .hm-media-preview {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #000;
    cursor: pointer;
  }

  .hm-media-preview[hidden] {
    display: none;
  }

  .hm-media-unmute {
    position: absolute;
    left: clamp(12px, 3vw, 20px);
    bottom: clamp(12px, 3vw, 20px);
    z-index: 4;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    margin: 0;
    border: 1px solid rgba(255, 255, 255, 0.35);
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    color: #fff;
    font-family: var(--font-body, 'Epilogue', sans-serif);
    font-size: clamp(13px, 2vw, 15px);
    font-weight: 600;
    letter-spacing: 0.02em;
    cursor: pointer;
    transition:
      transform 0.2s ease,
      background 0.2s ease,
      border-color 0.2s ease;
  }

  .hm-media-unmute[hidden] {
    display: none;
  }

  .hm-media-unmute:hover {
    transform: translateY(-1px);
    background: rgba(255, 84, 16, 0.92);
    border-color: rgba(255, 255, 255, 0.5);
  }

  .hm-media-unmute:focus-visible {
    outline: 2px solid #ff5410;
    outline-offset: 3px;
  }

  .hm-media-unmute-icon {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
  }

  .hm-media-unmute-text {
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .hm-media-unmute {
      bottom: clamp(48px, 14vw, 64px);
    }
  }

  .hm-media-play-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: clamp(72px, 14vw, 96px);
    height: clamp(72px, 14vw, 96px);
    padding: 0;
    margin: 0;
    border: 1px solid rgba(255, 255, 255, 0.4);
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.14);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    color: #fff;
    cursor: pointer;
    transition:
      transform 0.2s ease,
      background 0.2s ease,
      box-shadow 0.2s ease;
  }

  .hm-media-play-btn:hover {
    transform: scale(1.06);
    background: rgba(255, 255, 255, 0.22);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.35);
  }

  .hm-media-play-btn:focus-visible {
    outline: 2px solid #ff5410;
    outline-offset: 4px;
  }

  /* Badge esquina inferior derecha (mock Figma) */
  .hm-media-badge {
    position: absolute;
    right: clamp(16px, 4vw, 36px);
    bottom: clamp(18px, 4vw, 32px);
    top: auto;
    z-index: 3;
    transform: none;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    text-align: right;
    pointer-events: none;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.5);
  }

  .hm-media-badge-top {
    font-family: var(--font-body, 'Epilogue', sans-serif);
    font-size: clamp(15px, 2.4vw, 18px);
    font-weight: 500;
    color: #fff;
    letter-spacing: 0.02em;
  }

  .hm-media-badge-bottom {
    font-family: var(--font-body, 'Epilogue', sans-serif);
    font-size: clamp(26px, 5vw, 40px);
    font-weight: 600;
    font-style: italic;
    color: #fff;
    line-height: 1.05;
    margin-top: 2px;
    letter-spacing: -0.02em;
  }

  @media (max-width: 768px) {
    .hero-msg {
      width: 90%;
      padding: 28px 0 52px;
    }

    .hm-title {
      font-size: clamp(28px, 8.2vw, 34px);
    }

    .hm-pill-arrow {
      min-width: 40px;
      height: 26px;
      padding: 0 10px;
    }

    .hm-pill-arrow-icon {
      width: 17px;
      height: 17px;
    }

    .hm-media-badge {
      right: 16px;
      /* Un poco más arriba para no tapar la barra de controles del video en móvil */
      bottom: clamp(52px, 16vw, 72px);
    }
  }

  @media (max-width: 420px) {
    .hm-head {
      justify-content: flex-start;
    }

    .hm-title {
      width: 100%;
      max-width: 100%;
    }

    .hm-title-line--cta-row {
      gap: 8px 12px;
    }
  }

  .hm-lead-regular {
    font-weight: 300;
  }
</style>
