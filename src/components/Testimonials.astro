---
/** Carrusel de videos “Casos de éxito” — layout claro + puntos funcionales */
const videoCases = [
  { title: "Jhonny — Racks para TV", thumb: "/images/aduanaa.jpg" },
  { title: "María — Ropa deportiva", thumb: "/images/resource-1.jpg" },
  { title: "Carlos — Electrónicos", thumb: "/images/camion.jpg" },
  { title: "Cliente testimonio", thumb: "/images/probbd.png" },
  { title: "Importador consolidado", thumb: "/images/logisticweb.png" },
];

const testimonials = [
  {
    name: "Jhonny – Racks para TV",
    label: "CASO DE ÉXITO",
    stars: 5,
    text: "Importé racks para TV con Pro Business y fue una experiencia increíble. El proceso fue muy claro desde el inicio y llegué a tiempo a mi fecha clave.",
    avatar: "👤",
  },
  {
    name: "María – Ropa deportiva",
    label: "CASO DE ÉXITO",
    stars: 5,
    text: "Tenía miedo de importar por primera vez pero el equipo me guió en todo momento. Ahora ya voy en mi tercera importación sin ningún problema.",
    avatar: "👤",
  },
  {
    name: "Carlos – Electrónicos",
    label: "CASO DE ÉXITO",
    stars: 5,
    text: "Pro Business cumplió con todos los plazos y el servicio de inspección en tiempo real me dio mucha tranquilidad. Totalmente recomendable.",
    avatar: "👤",
  },
];
---

<section class="testimonials" aria-labelledby="testimonials-heading">
  <div class="t-container">
    <header class="testimonials-head">
      <p class="t-eyebrow">LO QUE DICEN <br /> NUESTROS CLIENTES</p>
      <h2 id="testimonials-heading" class="testimonials-title">
        Casos de <br />
        <span class="testimonials-title-accent">éxito</span>
      </h2>
    </header>
    <img
      src="/images/t_right_side.png"
      alt=""
      class="t-deco-img t-deco-img--left"
      aria-hidden="true"
    />
    <img
      src="/images/t_glass.png"
      alt=""
      class="t-deco-img t-deco-img--right"
      aria-hidden="true"
    />
    <svg
      class="t-deco-svg-mobile"
      xmlns="http://www.w3.org/2000/svg"
      width="196"
      height="529"
      viewBox="0 0 196 529"
      fill="none"
      aria-hidden="true"
    >
      <g filter="url(#filter0_f_2022_3323)">
        <path
          d="M277.306 498.195C153.203 517.736 24.5587 246.424 29.3505 177.15C34.1424 107.876 149.895 112.608 190.153 39.729C218.551 -11.6799 268.632 -93.8674 274.728 -146.985L274.65 -166.642C275.572 -160.709 275.546 -154.108 274.728 -146.985L277.306 498.195Z"
          fill="url(#paint0_radial_2022_3323)"></path>
      </g>
      <defs>
        <filter
          id="filter0_f_2022_3323"
          x="-7.43866e-05"
          y="-195.863"
          width="306.527"
          height="724.282"
          filterUnits="userSpaceOnUse"
          color-interpolation-filters="sRGB"
        >
          <feFlood flood-opacity="0" result="BackgroundImageFix"></feFlood>
          <feBlend
            mode="normal"
            in="SourceGraphic"
            in2="BackgroundImageFix"
            result="shape"></feBlend>
          <feGaussianBlur
            stdDeviation="14.6104"
            result="effect1_foregroundBlur_2022_3323"></feGaussianBlur>
        </filter>
        <radialGradient
          id="paint0_radial_2022_3323"
          cx="0"
          cy="0"
          r="1"
          gradientTransform="matrix(-279.25 -104.869 107.933 -750.597 276.873 226.036)"
          gradientUnits="userSpaceOnUse"
        >
          <stop offset="0.112961" stop-color="white" stop-opacity="0.93"></stop>
          <stop offset="0.250637" stop-color="#FF5410" stop-opacity="0.08"></stop>
          <stop offset="0.369792" stop-color="#FF5410" stop-opacity="0.47"></stop>
          <stop offset="0.493846" stop-color="#FF5410" stop-opacity="0.5"></stop>
          <stop offset="0.71875" stop-color="#FF5410"></stop>
          <stop offset="0.885417" stop-color="white"></stop>
        </radialGradient>
      </defs>
    </svg>
    <div class="t-carousel-wrap">
      <div
        class="t-carousel"
        id="t-carousel-track"
        tabindex="0"
        role="region"
        aria-label="Videos casos de éxito"
      >
        {
          videoCases.map((v, i) => (
            <a
              href="#"
              class="t-slide"
              aria-label={`Ver caso: ${v.title}`}
              data-t-slide
              data-t-slide-index={i}
            >
              <div class="t-slide-frame">
                <img
                  src={v.thumb}
                  alt=""
                  class="t-slide-img"
                  loading="lazy"
                  width="360"
                  height="640"
                />
                <div class="t-slide-overlay" />
                <span class="t-slide-play" aria-hidden="true">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="white">
                    <path d="M8 5v14l11-7z" />
                  </svg>
                </span>
              </div>
              <div class="t-slide-meta">
                <span class="t-slide-name">{v.title.toUpperCase()}</span>
                <span class="t-slide-tag">CASO DE ÉXITO</span>
              </div>
            </a>
          ))
        }
      </div>

      <div
        class="t-dots"
        role="tablist"
        aria-label="Página del carrusel"
        id="t-carousel-dots"
      >
        {
          videoCases.map((_, i) => (
            <button
              type="button"
              class:list={["t-dot", { "t-dot--active": i === 0 }]}
              role="tab"
              aria-selected={i === 0}
              aria-controls="t-carousel-track"
              data-t-dot={i}
            >
              <span class="visually-hidden">Video {i + 1}</span>
            </button>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  (() => {
    const track = document.getElementById("t-carousel-track");
    const dotsWrap = document.getElementById("t-carousel-dots");
    if (!track || !dotsWrap) return;

    const slides = () =>
      Array.from(track.querySelectorAll("[data-t-slide]"));
    const dots = () =>
      Array.from(dotsWrap.querySelectorAll("[data-t-dot]"));

    /**
     * Índice del slide con más ancho visible dentro del carrusel (encaja con peek + snap).
     * Usa getBoundingClientRect, no offsetLeft/scrollLeft.
     */
    function activeIndex() {
      if (!(track instanceof HTMLElement)) return 0;
      const trackRect = track.getBoundingClientRect();
      const trackMid = (trackRect.left + trackRect.right) / 2;
      const list = slides();
      let best = 0;
      let bestOverlap = -1;
      let bestCenterDist = Infinity;
      for (let i = 0; i < list.length; i++) {
        const el = list[i];
        if (!(el instanceof HTMLElement)) continue;
        const er = el.getBoundingClientRect();
        const left = Math.max(er.left, trackRect.left);
        const right = Math.min(er.right, trackRect.right);
        const overlap = Math.max(0, right - left);
        const elMid = (er.left + er.right) / 2;
        const centerDist = Math.abs(elMid - trackMid);
        if (
          overlap > bestOverlap ||
          (overlap === bestOverlap && centerDist < bestCenterDist)
        ) {
          bestOverlap = overlap;
          bestCenterDist = centerDist;
          best = i;
        }
      }
      return best;
    }

    /** Mientras no llegue el scroll al slide elegido (clic/tecla), no pisar el punto con activeIndex(). */
    let pendingDotIndex = null;
    let pendingDotClearTimer = 0;

    function setDots(i) {
      dots().forEach((btn, j) => {
        const on = j === i;
        btn.classList.toggle("t-dot--active", on);
        btn.setAttribute("aria-selected", on ? "true" : "false");
      });
    }

    function scrollToSlide(i) {
      const list = slides();
      const el = list[i];
      if (!el) return;
      if (!(el instanceof HTMLElement)) return;
      track.scrollTo({
        left: el.offsetLeft,
        behavior: "smooth",
      });
    }

    function goTo(i) {
      const list = slides();
      if (i < 0 || i >= list.length) return;
      window.clearTimeout(pendingDotClearTimer);
      pendingDotIndex = i;
      setDots(i);
      scrollToSlide(i);
      pendingDotClearTimer = window.setTimeout(() => {
        pendingDotIndex = null;
        syncDotsFromLayout();
      }, 700);
    }

    let ticking = false;
    let scrollSettleTimer = 0;

    function syncDotsFromLayout() {
      if (pendingDotIndex !== null) {
        setDots(pendingDotIndex);
        if (activeIndex() === pendingDotIndex) {
          pendingDotIndex = null;
        }
        return;
      }
      setDots(activeIndex());
    }

    track.addEventListener(
      "scroll",
      () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          syncDotsFromLayout();
          ticking = false;
        });
        window.clearTimeout(scrollSettleTimer);
        scrollSettleTimer = window.setTimeout(syncDotsFromLayout, 160);
      },
      { passive: true },
    );

    track.addEventListener("scrollend", syncDotsFromLayout);

    window.addEventListener("resize", syncDotsFromLayout, { passive: true });

    dotsWrap.addEventListener("click", (e) => {
      const tgt = e.target;
      const t = tgt instanceof Element ? tgt.closest("[data-t-dot]") : null;
      if (!t || (t instanceof HTMLButtonElement && t.disabled)) return;
      const i = Number(t.getAttribute("data-t-dot"));
      if (!Number.isNaN(i)) goTo(i);
    });

    track.addEventListener("keydown", (e) => {
      const list = slides();
      const cur = activeIndex();
      if (e.key === "ArrowRight") {
        e.preventDefault();
        goTo(Math.min(cur + 1, list.length - 1));
      } else if (e.key === "ArrowLeft") {
        e.preventDefault();
        goTo(Math.max(cur - 1, 0));
      }
    });

    syncDotsFromLayout();

    const io =
      typeof IntersectionObserver !== "undefined"
        ? new IntersectionObserver(
            () => {
              syncDotsFromLayout();
            },
            {
              root: track,
              rootMargin: "0px",
              threshold: [0, 0.05, 0.1, 0.15, 0.2, 0.25, 0.35, 0.5, 0.65, 0.8, 1],
            },
          )
        : null;
    if (io) {
      slides().forEach((el) => {
        if (el instanceof HTMLElement) io.observe(el);
      });
    }
  })();
</script>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .testimonials {
    position: relative;
    background: #fff;
    padding: 0 0 clamp(72px, 10vw, 120px) 0;
    overflow: hidden;
  }

  .t-container {
    position: relative;
    width: 100%;
  }

  .t-deco-img {
    position: absolute;
    top: 0;
    z-index: 0;
    pointer-events: none;

    height: auto;
  }

  .t-deco-img--left {
    left: 0;
  }

  .t-deco-img--right {
    right: 0;
    width: 700px;
    height: 300px;
  }

  .t-deco-svg-mobile {
    display: none;
    pointer-events: none;
  }

  /* Rayas decorativas arriba-derecha */
  .testimonials-stripes {
    pointer-events: none;
    position: absolute;
    top: 0;
    right: 0;
    width: min(42vw, 380px);
    height: min(42vw, 340px);
    background: repeating-linear-gradient(
      -80deg,
      rgba(255, 83, 15, 0) 0px,
      rgba(255, 83, 15, 0) 10px,
      rgba(255, 83, 15, 0.12) 10px,
      rgba(255, 83, 15, 0.28) 18px
    );
    mask-image: linear-gradient(
      to left,
      rgba(0, 0, 0, 0.85) 0%,
      transparent 75%
    );
    -webkit-mask-image: linear-gradient(
      to left,
      rgba(0, 0, 0, 0.85) 0%,
      transparent 75%
    );
  }

  .testimonials-head {
    position: relative;
    z-index: 1;
    margin-bottom: clamp(32px, 5vw, 48px);
    width:80%;
    margin: 0 auto;
    padding:2em 0;
  }

  .t-eyebrow {
    font-family: "Sora", var(--font-heading), sans-serif;
    font-size: 16px;
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #ff530f;
    margin: 0 0 14px;
  }

  .testimonials-title {
    font-family: Epilogue;
    font-size: clamp(40px, 6vw, 64px);
    font-weight: 300;
    color: #000;
    letter-spacing: -0.06em;
    line-height: 1.02;
    margin: 0;
  }

  .testimonials-title-accent {
    background: var(
      --ORANGE-WHITE,
      linear-gradient(90deg, #000 0%, #ff5410 25.48%)
    );
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-size: 64px;
    font-style: normal;
    font-weight: 300;
    line-height: 90%;
    letter-spacing: -3.84px;
  }
  @media (max-width: 768px) {
    .testimonials-title-accent {
      font-size: 34px;
    }
    .testimonials-title {
      font-size: 34px;
    }
  }

  .t-carousel-wrap {
    position: relative;
    z-index: 1;
    margin-bottom: clamp(40px, 6vw, 64px);
    width: 80%;
    margin: 0 auto;
  }

  .t-carousel {
    --t-gap: clamp(16px, 2.5vw, 24px);
    display: flex;
    gap: var(--t-gap);
    width: 100%;
    box-sizing: border-box;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding: 8px 4px 20px;
    margin: 0 -8px;
    scrollbar-width: none;
    -ms-overflow-style: none;
    outline: none;
  }

  .t-carousel::-webkit-scrollbar {
    display: none;
  }

  /* ≤900px: carrusel horizontal con “peek” del siguiente slide */
  .t-slide {
    box-sizing: border-box;
    flex: 0 0 calc(100% - clamp(40px, 12vw, 56px));
    width: calc(100% - clamp(40px, 12vw, 56px));
    min-width: calc(100% - clamp(40px, 12vw, 56px));
    scroll-snap-align: start;
    scroll-snap-stop: normal;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: transform 0.2s ease;
  }

  .t-slide:hover {
    transform: translateY(-4px);
  }

  .t-slide:focus-visible {
    outline: 2px solid #ff530f;
    outline-offset: 6px;
    border-radius: 16px;
  }

  /* Marco vertical oscuro tipo “video” */
  .t-slide-frame {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 9 / 16;
    min-height: 260px;
    background: #1a1a1a;
  }

  .t-slide-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
    opacity: 0.35;
    filter: saturate(0.85);
  }

  .t-slide-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.2) 0%,
      rgba(0, 0, 0, 0.75) 100%
    );
  }

  .t-slide-play {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(160deg, #9a9a9a 0%, #4a4a4a 45%, #2d2d2d 100%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.25),
      0 8px 24px rgba(0, 0, 0, 0.35);
  }

  .t-slide-play svg {
    margin-left: 4px;
    filter: drop-shadow(0 1px 1px rgba(0, 0, 0, 0.3));
  }

  .t-slide-meta {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 0 2px;
  }

  .t-slide-name {
    font-family: "Sora", var(--font-heading), sans-serif;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: #000;
    line-height: 1.25;
  }

  .t-slide-tag {
    font-family: "Sora", var(--font-heading), sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #ff530f;
  }

  .t-dots {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    margin-top: 8px;
  }

  .t-dot {
    width: 10px;
    height: 10px;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: #d0d0d0;
    cursor: pointer;
    transition:
      background 0.2s ease,
      transform 0.2s ease;
  }

  .t-dot:hover {
    background: #b0b0b0;
    transform: scale(1.1);
  }

  .t-dot--active {
    background: #ff530f;
    transform: scale(1.15);
  }

  .t-dot--active:hover {
    background: #ff530f;
    transform: scale(1.15);
  }

  .t-dot:focus-visible {
    outline: 2px solid #ff530f;
    outline-offset: 3px;
  }

  /* Web / >900px: exactamente 3 tarjetas visibles (sin “peek” del siguiente) */
  @media (min-width: 901px) {
    .t-slide {
      flex: 0 0 calc((100% - 2 * var(--t-gap)) / 3);
      width: auto;
      min-width: 0;
      scroll-snap-stop: normal;
    }

    .t-slide-frame {
      min-height: 300px;
    }
  }

  /* Tarjetas de texto: contraste sobre fondo blanco */
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 60px;
  }

  .t-card {
    background: #f7f7f7;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: var(--radius-card);
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition:
      transform 0.2s,
      box-shadow 0.2s;
  }

  .t-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
  }

  .t-card-header {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .t-avatar {
    width: 68px;
    height: 68px;
    border-radius: 50%;
    background: #e8e8e8;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 32px;
    flex-shrink: 0;
    overflow: hidden;
  }

  .t-label {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    color: #ff530f;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  .t-name {
    font-family: "Sora", var(--font-heading), sans-serif;
    font-size: 18px;
    font-weight: 600;
    color: #000;
    line-height: 1.2;
  }

  .t-stars {
    display: flex;
    gap: 2px;
  }

  .t-star {
    color: #ff530f;
    font-size: 20px;
  }

  .t-text {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    color: #444;
    line-height: 1.6;
    flex: 1;
  }

  .whatsapp-cta-wrap {
    display: flex;
    justify-content: center;
  }

  .whatsapp-cta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 20px 48px;
    background: linear-gradient(to right, #25cf43, #61fd7d);
    border-radius: 17px;
    font-family: var(--font-body);
    font-size: 24px;
    font-weight: 500;
    color: #000;
    text-decoration: none;
    transition:
      transform 0.2s,
      box-shadow 0.2s;
  }

  .whatsapp-cta:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(37, 207, 67, 0.35);
  }

  @media (max-width: 900px) {
    .testimonials-grid {
      grid-template-columns: 1fr;
      max-width: 520px;
      margin-left: auto;
      margin-right: auto;
    }

    .whatsapp-cta {
      font-size: 18px;
      padding: 16px 32px;
    }

    /* Carrusel “peek”: recorte centrado en el marco + texto centrado bajo la foto */
    .t-slide-img {
      object-fit: cover;
      object-position: center center;
    }

    .t-slide-meta {
      align-items: center;
      text-align: center;
      padding-inline: 8px;
    }

    .t-slide-name,
    .t-slide-tag {
      text-align: center;
      max-width: 100%;
    }
  }

  @media (max-width: 768px) {
    .t-deco-img {
      display: none;
    }

    .t-deco-svg-mobile {
      display: block;
      position: absolute;
      right: 0;
      top: -32px;
      width: min(160px, 42vw);
      height: auto;
      z-index: 0;
      opacity: 1;
    }
  }
</style>
