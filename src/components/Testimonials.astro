---
/** Carrusel de videos “Casos de éxito” — layout claro + puntos funcionales */
const videoCases = [
  { title: "Jhonny — Racks para TV", thumb: "/images/aduanaa.jpg" },
  { title: "María — Ropa deportiva", thumb: "/images/resource-1.jpg" },
  { title: "Carlos — Electrónicos", thumb: "/images/camion.jpg" },
  { title: "Cliente testimonio", thumb: "/images/probbd.png" },
  { title: "Importador consolidado", thumb: "/images/logisticweb.png" },
];

const testimonials = [
  {
    name: "Jhonny – Racks para TV",
    label: "CASO DE ÉXITO",
    stars: 5,
    text: "Importé racks para TV con Pro Business y fue una experiencia increíble. El proceso fue muy claro desde el inicio y llegué a tiempo a mi fecha clave.",
    avatar: "👤",
  },
  {
    name: "María – Ropa deportiva",
    label: "CASO DE ÉXITO",
    stars: 5,
    text: "Tenía miedo de importar por primera vez pero el equipo me guió en todo momento. Ahora ya voy en mi tercera importación sin ningún problema.",
    avatar: "👤",
  },
  {
    name: "Carlos – Electrónicos",
    label: "CASO DE ÉXITO",
    stars: 5,
    text: "Pro Business cumplió con todos los plazos y el servicio de inspección en tiempo real me dio mucha tranquilidad. Totalmente recomendable.",
    avatar: "👤",
  },
];
---

<section class="testimonials" aria-labelledby="testimonials-heading">
  <div class="t-container" style="position: relative;width:100%;">
    <header class="testimonials-head">
      <p class="t-eyebrow">LO QUE DICEN <br /> NUESTROS CLIENTES</p>
      <h2 id="testimonials-heading" class="testimonials-title">
        Casos de <br />
        <span class="testimonials-title-accent">éxito</span>
      </h2>
    </header>
    <img src="/images/t_right_side.png" alt="Testimonials Deco"  style="position: absolute; left: 0; top: 0;" />
    <img src="/images/t_glass.png" alt="Testimonials Deco"  style="position: absolute; right: 0; top: 0;" />
    <div class="t-carousel-wrap">
      <div
        class="t-carousel"
        id="t-carousel-track"
        tabindex="0"
        role="region"
        aria-label="Videos casos de éxito"
      >
        {
          videoCases.map((v) => (
            <a
              href="#"
              class="t-slide"
              aria-label={`Ver caso: ${v.title}`}
              data-t-slide
            >
              <div class="t-slide-frame">
                <img
                  src={v.thumb}
                  alt=""
                  class="t-slide-img"
                  loading="lazy"
                  width="360"
                  height="640"
                />
                <div class="t-slide-overlay" />
                <span class="t-slide-play" aria-hidden="true">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="white">
                    <path d="M8 5v14l11-7z" />
                  </svg>
                </span>
              </div>
              <div class="t-slide-meta">
                <span class="t-slide-name">{v.title.toUpperCase()}</span>
                <span class="t-slide-tag">CASO DE ÉXITO</span>
              </div>
            </a>
          ))
        }
      </div>

      <div
        class="t-dots"
        role="tablist"
        aria-label="Página del carrusel"
        id="t-carousel-dots"
      >
        {
          videoCases.map((_, i) => (
            <button
              type="button"
              class:list={["t-dot", { "t-dot--active": i === 0 }]}
              role="tab"
              aria-selected={i === 0}
              aria-controls="t-carousel-track"
              data-t-dot={i}
            >
              <span class="visually-hidden">Video {i + 1}</span>
            </button>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  (() => {
    const track = document.getElementById("t-carousel-track");
    const dotsWrap = document.getElementById("t-carousel-dots");
    if (!track || !dotsWrap) return;

    const slides = () => Array.from(track.querySelectorAll("[data-t-slide]"));
    const dots = () => Array.from(dotsWrap.querySelectorAll("[data-t-dot]"));

    function activeIndex() {
      const list = slides();
      if (!list.length) return 0;
      const sl = track.scrollLeft;
      let best = 0;
      let bestDist = Infinity;
      list.forEach((el, i) => {
        const left = el instanceof HTMLElement ? el.offsetLeft : 0;
        const d = Math.abs(left - sl);
        if (d < bestDist) {
          bestDist = d;
          best = i;
        }
      });
      return best;
    }

    function setDots(i) {
      dots().forEach((btn, j) => {
        const on = j === i;
        btn.classList.toggle("t-dot--active", on);
        btn.setAttribute("aria-selected", on ? "true" : "false");
      });
    }

    function goTo(i) {
      const list = slides();
      const el = list[i];
      if (!el) return;
      el.scrollIntoView({
        behavior: "smooth",
        inline: "start",
        block: "nearest",
      });
      setDots(i);
    }

    let ticking = false;
    track.addEventListener(
      "scroll",
      () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          setDots(activeIndex());
          ticking = false;
        });
      },
      { passive: true },
    );

    dotsWrap.addEventListener("click", (e) => {
      const tgt = e.target;
      const t = tgt instanceof Element ? tgt.closest("[data-t-dot]") : null;
      if (!t || (t instanceof HTMLButtonElement && t.disabled)) return;
      const i = Number(t.getAttribute("data-t-dot"));
      if (!Number.isNaN(i)) goTo(i);
    });

    track.addEventListener("keydown", (e) => {
      const list = slides();
      const cur = activeIndex();
      if (e.key === "ArrowRight") {
        e.preventDefault();
        goTo(Math.min(cur + 1, list.length - 1));
      } else if (e.key === "ArrowLeft") {
        e.preventDefault();
        goTo(Math.max(cur - 1, 0));
      }
    });

    setDots(0);
  })();
</script>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .testimonials {
    position: relative;
    background: #fff;
    padding: clamp(72px, 10vw, 120px) 0;
    overflow: hidden;
  }

  /* Rayas decorativas arriba-derecha */
  .testimonials-stripes {
    pointer-events: none;
    position: absolute;
    top: 0;
    right: 0;
    width: min(42vw, 380px);
    height: min(42vw, 340px);
    background: repeating-linear-gradient(
      -80deg,
      rgba(255, 83, 15, 0) 0px,
      rgba(255, 83, 15, 0) 10px,
      rgba(255, 83, 15, 0.12) 10px,
      rgba(255, 83, 15, 0.28) 18px
    );
    mask-image: linear-gradient(
      to left,
      rgba(0, 0, 0, 0.85) 0%,
      transparent 75%
    );
    -webkit-mask-image: linear-gradient(
      to left,
      rgba(0, 0, 0, 0.85) 0%,
      transparent 75%
    );
  }

  .testimonials-head {
    position: relative;
    z-index: 1;
    margin-bottom: clamp(32px, 5vw, 48px);
    width:80%;
    margin: 0 auto;
  }

  .t-eyebrow {
    font-family: "Sora", var(--font-heading), sans-serif;
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #ff530f;
    margin: 0 0 14px;
  }

  .testimonials-title {
    font-family: Epilogue;
    font-size: clamp(40px, 6vw, 64px);
    font-weight: 300;
    color: #000;
    letter-spacing: -0.06em;
    line-height: 1.02;
    margin: 0;
  }

  .testimonials-title-accent {
    background: var(
      --ORANGE-WHITE,
      linear-gradient(90deg, #000 0%, #ff5410 25.48%)
    );
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-size: 64px;
    font-style: normal;
    font-weight: 300;
    line-height: 90%;
    letter-spacing: -3.84px;
  }

  .t-carousel-wrap {
    position: relative;
    z-index: 1;
    margin-bottom: clamp(40px, 6vw, 64px);
    width: 80%;
    margin: 0 auto;
  }

  .t-carousel {
    --t-gap: clamp(16px, 2.5vw, 24px);
    display: flex;
    gap: var(--t-gap);
    width: 100%;
    box-sizing: border-box;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    padding: 8px 4px 20px;
    margin: 0 -8px;
    scrollbar-width: none;
    -ms-overflow-style: none;
    outline: none;
  }

  .t-carousel::-webkit-scrollbar {
    display: none;
  }

  /* Mobile / ≤900px: 1 tarjeta visible a la vez */
  .t-slide {
    box-sizing: border-box;
    flex: 0 0 100%;
    width: 100%;
    min-width: 0;
    scroll-snap-align: start;
    scroll-snap-stop: always;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: transform 0.2s ease;
  }

  .t-slide:hover {
    transform: translateY(-4px);
  }

  .t-slide:focus-visible {
    outline: 2px solid #ff530f;
    outline-offset: 6px;
    border-radius: 16px;
  }

  /* Marco vertical oscuro tipo “video” */
  .t-slide-frame {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 9 / 16;
    min-height: 260px;
    background: #1a1a1a;
  }

  .t-slide-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0.35;
    filter: saturate(0.85);
  }

  .t-slide-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.2) 0%,
      rgba(0, 0, 0, 0.75) 100%
    );
  }

  .t-slide-play {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(160deg, #9a9a9a 0%, #4a4a4a 45%, #2d2d2d 100%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.25),
      0 8px 24px rgba(0, 0, 0, 0.35);
  }

  .t-slide-play svg {
    margin-left: 4px;
    filter: drop-shadow(0 1px 1px rgba(0, 0, 0, 0.3));
  }

  .t-slide-meta {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 0 2px;
  }

  .t-slide-name {
    font-family: "Sora", var(--font-heading), sans-serif;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: #000;
    line-height: 1.25;
  }

  .t-slide-tag {
    font-family: "Sora", var(--font-heading), sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #ff530f;
  }

  .t-dots {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    margin-top: 8px;
  }

  .t-dot {
    width: 10px;
    height: 10px;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: #d0d0d0;
    cursor: pointer;
    transition:
      background 0.2s ease,
      transform 0.2s ease;
  }

  .t-dot:hover {
    background: #b0b0b0;
    transform: scale(1.1);
  }

  .t-dot--active {
    background: #ff530f;
    transform: scale(1.15);
  }

  .t-dot:focus-visible {
    outline: 2px solid #ff530f;
    outline-offset: 3px;
  }

  /* Web / >900px: exactamente 3 tarjetas visibles (sin “peek” del siguiente) */
  @media (min-width: 901px) {
    .t-slide {
      flex: 0 0 calc((100% - 2 * var(--t-gap)) / 3);
      width: auto;
      scroll-snap-stop: normal;
    }

    .t-slide-frame {
      min-height: 300px;
    }
  }

  /* Tarjetas de texto: contraste sobre fondo blanco */
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 60px;
  }

  .t-card {
    background: #f7f7f7;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: var(--radius-card);
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition:
      transform 0.2s,
      box-shadow 0.2s;
  }

  .t-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
  }

  .t-card-header {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .t-avatar {
    width: 68px;
    height: 68px;
    border-radius: 50%;
    background: #e8e8e8;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 32px;
    flex-shrink: 0;
    overflow: hidden;
  }

  .t-label {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    color: #ff530f;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  .t-name {
    font-family: "Sora", var(--font-heading), sans-serif;
    font-size: 18px;
    font-weight: 600;
    color: #000;
    line-height: 1.2;
  }

  .t-stars {
    display: flex;
    gap: 2px;
  }

  .t-star {
    color: #ff530f;
    font-size: 20px;
  }

  .t-text {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    color: #444;
    line-height: 1.6;
    flex: 1;
  }

  .whatsapp-cta-wrap {
    display: flex;
    justify-content: center;
  }

  .whatsapp-cta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 20px 48px;
    background: linear-gradient(to right, #25cf43, #61fd7d);
    border-radius: 17px;
    font-family: var(--font-body);
    font-size: 24px;
    font-weight: 500;
    color: #000;
    text-decoration: none;
    transition:
      transform 0.2s,
      box-shadow 0.2s;
  }

  .whatsapp-cta:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(37, 207, 67, 0.35);
  }

  @media (max-width: 900px) {
    .testimonials-grid {
      grid-template-columns: 1fr;
      max-width: 520px;
      margin-left: auto;
      margin-right: auto;
    }

    .whatsapp-cta {
      font-size: 18px;
      padding: 16px 32px;
    }
  }
</style>
