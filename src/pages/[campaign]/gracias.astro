---
import campaignsData from "../../data/campaigns.json";
import Layout from "../../layouts/Layout.astro";

export function getStaticPaths() {
  return campaignsData.campaigns.map((c) => ({
    params: { campaign: c.codigo },
  }));
}

const { campaign } = Astro.params;
const entry = campaignsData.campaigns.find((c) => c.codigo === campaign)!;
const homePath = `/${entry.codigo}/`;
---

<Layout title="Gracias por comunicarte | Pro Business" hideFloatingCta={true}>
  <script is:inline define:vars={{ homePath }}>
    (function () {
      const SUCCESS_FLAG_KEY = "leadFormConfirmed";
      const SUCCESS_AT_KEY = "leadFormConfirmedAt";
      const ACCESS_TTL_MS = 10 * 60 * 1000;
      const hasConfirmed = sessionStorage.getItem(SUCCESS_FLAG_KEY) === "1";
      const confirmedAt = Number(sessionStorage.getItem(SUCCESS_AT_KEY) || "0");
      const isFresh =
        Number.isFinite(confirmedAt) && Date.now() - confirmedAt <= ACCESS_TTL_MS;

      if (!hasConfirmed || !isFresh) {
        window.location.replace(homePath);
        return;
      }

      document.documentElement.classList.add("thanks-authorized");
      sessionStorage.removeItem(SUCCESS_FLAG_KEY);
    })();
  </script>

  <main class="thanks-page">
    <section class="thanks-card-wrap">
      <article class="thanks-card">
        <img class="thanks-logo" src="/images/logo-hero.png" alt="Pro Business" width="127" height="26" />

        <div class="thanks-content">
          <img
            class="thanks-icon"
            src="/images/thanks-img.png"
            alt="Icono de mensaje recibido"
            width="320"
            height="320"
          />
          <div class="thanks-copy">
            <h1>Gracias por <span>registrarte</span></h1>
            <p>
              Pronto nuestro equipo de Pro Business se pondrá en contacto con usted para ayudarlo en su proceso de
              importación.
            </p>
            <a class="thanks-home-btn" href={homePath}>Volver al Inicio</a>
          </div>
        </div>
      </article>
      <p class="thanks-footer">© 2026 Pro Business - Curso de Importación desde China</p>
    </section>
  </main>
</Layout>

<style>
  .thanks-page {
    display: none;
    min-height: 100svh;
    background: #000;
    color: #fff;
    place-items: center;
    padding: 0;
  }

  :global(html.thanks-authorized) .thanks-page {
    display: grid;
  }

  .thanks-card-wrap {
    width: 100%;
  }

  .thanks-card {
    position: relative;
    background: #050505;
    border: none;
    border-radius: 0;
    padding: clamp(18px, 3vw, 34px) clamp(16px, 4vw, 40px);
    min-height: 100svh;
    width: 100%;
    box-sizing: border-box;
  }

  .thanks-logo {
    display: block;
    width: 136px;
    height: auto;
    margin: 4px 0 clamp(24px, 5vw, 56px);
  }

  .thanks-content {
    width: min(1050px, 96%);
    margin: 0 auto;
    background: linear-gradient(125deg, #17181b 0%, #1a1b1f 58%, #181a1d 100%);
    border-radius: 28px;
    display: grid;
    grid-template-columns: minmax(180px, 290px) 1fr;
    gap: clamp(20px, 5vw, 54px);
    align-items: center;
    padding: clamp(24px, 5vw, 52px);
    position: relative;
    overflow: hidden;
  }

  .thanks-content::after {
    content: "";
    position: absolute;
    width: 260px;
    height: 260px;
    right: -88px;
    top: -88px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 83, 15, 0.72) 0%, rgba(255, 83, 15, 0) 70%);
    pointer-events: none;
  }

  .thanks-icon {
    width: clamp(150px, 23vw, 250px);
    height: auto;
    justify-self: center;
  }

  .thanks-copy h1 {
    margin: 0 0 14px;
    font-family: "Sora", sans-serif;
    font-size: clamp(2rem, 5vw, 4rem);
    line-height: 0.98;
    letter-spacing: -0.02em;
    font-weight: 500;
  }

  .thanks-copy h1 span {
    color: #ff530f;
  }

  .thanks-copy p {
    margin: 0 0 24px;
    max-width: 36ch;
    font-family: "Epilogue", sans-serif;
    color: #e6e6e6;
    font-size: clamp(1rem, 2vw, 1.6rem);
    line-height: 1.2;
  }

  .thanks-home-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 44px;
    padding: 0 18px;
    border-radius: 10px;
    border: none;
    text-decoration: none;
    background: #ff530f;
    color: #0c0c0c;
    font-family: "Epilogue", sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    transition:
      transform 0.2s ease,
      background 0.2s ease;
  }

  .thanks-home-btn:hover {
    background: #ff6b32;
    transform: translateY(-1px);
  }

  .thanks-home-btn:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }

  .thanks-footer {
    text-align: center;
    margin: 18px 0 0;
    color: #9a9a9a;
    font-family: "Epilogue", sans-serif;
    font-size: 0.9rem;
  }

  @media (max-width: 840px) {
    .thanks-content {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .thanks-copy p {
      margin-inline: auto;
    }
  }
</style>
