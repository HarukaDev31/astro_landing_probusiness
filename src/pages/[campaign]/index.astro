---
import campaignsData from "../../data/campaigns.json";
import Layout from "../../layouts/Layout.astro";
import AnnouncementBar from "../../components/AnnouncementBar.astro";
import Navbar from "../../components/Navbar.astro";
import Hero from "../../components/Hero.astro";
import HeroMessaging from "../../components/HeroMessaging.astro";
import PointSection from "../../components/PointSection.astro";
import HowItWorks from "../../components/HowItWorks.astro";
import Testimonials from "../../components/Testimonials.astro";
import CTASection from "../../components/CTASection.astro";
import LeadForm from "../../components/LeadForm.astro";
import TrustSection from "../../components/TrustSection.astro";
import Footer from "../../components/Footer.astro";

export function getStaticPaths() {
  return campaignsData.campaigns.map((c) => ({
    params: { campaign: c.codigo },
  }));
}

const { campaign } = Astro.params;
const entry = campaignsData.campaigns.find((c) => c.codigo === campaign)!;

const soonDates = [entry.labelInicio, entry.labelFin];
const graciasPath = `/${entry.codigo}/gracias`;
---

<Layout>
  <header class="site-header">
    <AnnouncementBar />
    <Navbar />
  </header>
  <Hero soonDates={soonDates} />
  <HeroMessaging />
  <PointSection />
  <HowItWorks />
  <Testimonials />
  <CTASection />
  <LeadForm campaignCode={entry.codigo} graciasPath={graciasPath} />
  <TrustSection />
  <Footer />
</Layout>

<style>
  .site-header {
    position: relative;
    z-index: 110;
  }
</style>
