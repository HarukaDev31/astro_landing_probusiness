  </body>
</html>

<style>
  .floating-form-cta {
    position: fixed;
    right: 14px;
    bottom: 18px;
    z-index: 999;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-decoration: none;
  }

  .floating-form-cta__label {
    font-family: "Epilogue", sans-serif;
    font-size: 12px;
    line-height: 1.05;
    text-align: center;
    color: #fff;

    text-underline-offset: 2px;
  }

  .floating-form-cta__icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    background: #ff5410;
    box-shadow: 0 0 24px rgba(255, 84, 16, 0.7);
  }

  .floating-form-cta:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 4px;
    border-radius: 10px;
  }
</style>
