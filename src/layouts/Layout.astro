        height="1"
        width="1"
        style="display:none"
        src="https://www.facebook.com/tr?id=845979755184987&ev=PageView&noscript=1"
      />
    </noscript>
    <!-- End Meta Pixel Code (noscript) -->
    <slot />
    {
      !hideFloatingCta && (
        <a href="#form" class="floating-form-cta" aria-label="Ir al formulario de cotización">
          <span class="floating-form-cta__label">Cotizar<br />Ahora</span>
          <span class="floating-form-cta__icon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 26 26" fill="none" xmlns="http://www.w3.org/2000/svg">
